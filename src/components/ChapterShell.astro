---
import ReportLayout from "../layouts/ReportLayout.astro";
import Section from "./Section.astro";
import {
  adjacentChapters,
  chapterHref,
  chapterNavItems,
  getChapter,
  type ChapterId,
} from "../lib/chapters";
import { LAYER_LABELS, chrome, localePath, type Locale } from "../lib/i18n";

interface Props {
  chapterId: ChapterId;
  locale?: Locale;
  /** Extra description for <meta>; defaults to question. */
  description?: string;
}

const { chapterId, locale = "zh", description } = Astro.props;
const chapter = getChapter(chapterId);
const { prev, next } = adjacentChapters(chapterId);
const nav = chapterNavItems(locale);
const t = chrome(locale);
const layers = LAYER_LABELS[locale];
const metaDescription =
  description ?? (locale === "en" ? chapter.questionEn : chapter.questionZh);
const titlePrimary = locale === "en" ? chapter.titleEn : chapter.titleZh;
const titleSecondary = locale === "en" ? chapter.titleZh : chapter.titleEn;
const question = locale === "en" ? chapter.questionEn : chapter.questionZh;
const lede = locale === "en" ? chapter.ledeEn : chapter.ledeZh;
const selfHref = chapterHref(chapter.slug, locale);
const historyHref = localePath(locale, "history");
const guideHref = localePath(locale, "");
const isDone = chapter.status === "done";
const statusLabel = isDone ? t.statusDone : t.statusWip;
const draftOrDone = isDone ? t.doneLabel : t.draftLabel;
---

<ReportLayout
  title={`§${chapter.id} ${chapter.titleEn} · Agent Atelier`}
  description={metaDescription}
  nav={nav}
  activeHref={selfHref}
  locale={locale}
>
  <article class="report">
    <header class="masthead">
      <p class="masthead__eyebrow">
        §{chapter.id} · {chapter.titleEn} · {draftOrDone}
      </p>
      <h1>
        <span class="masthead__title-zh">{titlePrimary}</span>
        <span class="masthead__title-en">{titleSecondary}</span>
      </h1>
      <p class="masthead__sub">{question}</p>
      <div class="masthead__meta">
        <span>{t.layer} · {layers[chapter.layer]}</span>
        <span>{t.specimen}</span>
        <span>{statusLabel}</span>
        <span>
          {t.historyTrack} · <a href={historyHref}>/history</a>
        </span>
      </div>
    </header>

    {
      !isDone && (
        <aside class="stub" aria-label="WIP">
          <p class="stub__tag">{t.chapterWipTag}</p>
          <p>
            {t.chapterWipBody}
            {locale === "zh" && (
              <span>
                {" "}
                详见
                <a href="https://github.com/tt-a1i/agent-atelier/issues/6">验收清单</a>。
              </span>
            )}
          </p>
        </aside>
      )
    }

    <Section
      id="thesis"
      label={`§${chapter.id} · ${t.thesisLabel}`}
      title={t.thesisTitle}
      lede={lede}
    >
      <p>
        {locale === "en" ? "Core question: " : "核心问题："}
        {question}
      </p>
      {
        locale === "zh" ? (
          <p class="thesis-en" lang="en">
            <span class="thesis-en__label">EN question</span>
            {chapter.questionEn}
          </p>
        ) : (
          <p class="thesis-en" lang="zh-CN">
            <span class="thesis-en__label">中文问题</span>
            {chapter.questionZh}
          </p>
        )
      }
      <slot name="thesis" />
    </Section>

    <slot />

    <Section
      id="outline"
      label={`§${chapter.id} · ${t.outlineLabel}`}
      title={t.outlineTitle}
      lede={t.outlineLede}
    >
      <slot name="outline">
        <ul class="outline-list">
          {
            t.outlineDefaults.map((item) => (
              <li>
                {item.includes("/history") ? (
                  <span>
                    {item.split("/history")[0]}
                    <a href={historyHref}>/history</a>
                    {item.split("/history")[1] ?? ""}
                  </span>
                ) : (
                  item
                )}
              </li>
            ))
          }
        </ul>
      </slot>
    </Section>

    <nav class="chapter-pager" aria-label={locale === "en" ? "Adjacent chapters" : "相邻章节"}>
      {
        prev ? (
          <a
            class="chapter-pager__link chapter-pager__link--prev"
            href={chapterHref(prev.slug, locale)}
          >
            <span class="chapter-pager__dir">{t.pagerPrev}</span>
            <span class="chapter-pager__title">
              §{prev.id} {locale === "en" ? prev.titleEn : prev.titleZh}
            </span>
          </a>
        ) : (
          <a class="chapter-pager__link chapter-pager__link--prev" href={guideHref}>
            <span class="chapter-pager__dir">{t.pagerBack}</span>
            <span class="chapter-pager__title">{t.pagerGuide}</span>
          </a>
        )
      }
      {
        next ? (
          <a
            class="chapter-pager__link chapter-pager__link--next"
            href={chapterHref(next.slug, locale)}
          >
            <span class="chapter-pager__dir">{t.pagerNext}</span>
            <span class="chapter-pager__title">
              §{next.id} {locale === "en" ? next.titleEn : next.titleZh}
            </span>
          </a>
        ) : (
          <a class="chapter-pager__link chapter-pager__link--next" href={historyHref}>
            <span class="chapter-pager__dir">{t.pagerHistory}</span>
            <span class="chapter-pager__title">/history</span>
          </a>
        )
      }
    </nav>
  </article>
</ReportLayout>

<style>
  .masthead h1 {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .masthead__title-zh {
    display: block;
  }

  .masthead__title-en {
    display: block;
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.15rem, 2.4vw, 1.45rem);
    color: var(--mute);
    letter-spacing: -0.01em;
  }

  .thesis-en {
    margin-top: 1.1rem;
    padding: 0.85rem 1rem;
    background: var(--softer);
    border: 1px solid var(--hair);
    font-family: var(--serif);
    font-style: italic;
    color: var(--mute);
    max-width: 40em;
  }

  .thesis-en__label {
    display: block;
    font-family: var(--mono);
    font-style: normal;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
    color: var(--accent);
  }

  .outline-list {
    margin: 0.75rem 0 0;
    padding-left: 1.2rem;
    max-width: 40em;
  }

  .outline-list li {
    margin-bottom: 0.45rem;
  }

  .chapter-pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2.75rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--hair);
  }

  .chapter-pager__link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.85rem 0;
    text-decoration: none;
    color: var(--ink);
    min-width: 0;
  }

  .chapter-pager__link:hover .chapter-pager__title {
    color: var(--accent);
  }

  .chapter-pager__link--next {
    text-align: right;
  }

  .chapter-pager__dir {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mute);
  }

  .chapter-pager__title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 600;
    transition: color 0.15s ease;
  }

  @media (max-width: 560px) {
    .chapter-pager {
      grid-template-columns: 1fr;
    }

    .chapter-pager__link--next {
      text-align: left;
    }
  }
</style>
