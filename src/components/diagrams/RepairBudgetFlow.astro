---
/**
 * §05 flow — fail → repair Turn under cap → stop when budget exhausted.
 */
---

<svg
  class="rb-flow"
  viewBox="0 0 868 220"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <defs>
    <marker
      id="rb-arrow"
      viewBox="0 0 10 10"
      refX="9"
      refY="5"
      markerWidth="6"
      markerHeight="6"
      orient="auto-start-reverse"
    >
      <path d="M 0 1.5 L 9 5 L 0 8.5 Z" fill="var(--accent)"></path>
    </marker>
  </defs>

  <text class="rb-kicker rb-stage rb-stage--0" x="8" y="20" fill="var(--accent)">
    FLOW · BOUNDED REPAIR · NO INFINITE SELF-AUTHORITY
  </text>
  <line
    class="rb-stage rb-stage--0"
    x1="8"
    y1="34"
    x2="860"
    y2="34"
    stroke="var(--hair)"
    stroke-width="1"
  ></line>

  <g class="rb-connectors rb-stage rb-stage--1" stroke="var(--accent)" stroke-width="1.25" fill="none">
    <line x1="178" y1="110" x2="206" y2="110" marker-end="url(#rb-arrow)"></line>
    <line x1="354" y1="110" x2="382" y2="110" marker-end="url(#rb-arrow)"></line>
    <line x1="530" y1="110" x2="558" y2="110" marker-end="url(#rb-arrow)"></line>
    <line x1="706" y1="110" x2="734" y2="110" marker-end="url(#rb-arrow)"></line>
  </g>

  <g class="rb-node rb-stage rb-stage--1" transform="translate(8,58)">
    <rect width="170" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="170" height="2" fill="var(--accent)"></rect>
    <text class="rb-node__idx" x="12" y="26" fill="var(--accent)">01</text>
    <text class="rb-node__name" x="12" y="50" fill="var(--ink)">Gate fails</text>
    <text class="rb-node__hint" x="12" y="74" fill="var(--mute)">semantic / hygiene</text>
    <text class="rb-node__hint" x="12" y="92" fill="var(--mute)">or source guard</text>
  </g>

  <g class="rb-node rb-stage rb-stage--2" transform="translate(206,58)">
    <rect width="148" height="104" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)" opacity="0.7"></rect>
    <text class="rb-node__idx" x="12" y="26" fill="var(--accent)">02</text>
    <text class="rb-node__name" x="12" y="50" fill="var(--ink)">Budget check</text>
    <text class="rb-node__hint" x="12" y="74" fill="var(--mute)">repair turns left?</text>
    <text class="rb-node__hint" x="12" y="92" fill="var(--mute)">Runtime owns cap</text>
  </g>

  <g class="rb-node rb-stage rb-stage--3" transform="translate(382,58)">
    <rect width="148" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="rb-node__idx" x="12" y="26" fill="var(--accent)">03</text>
    <text class="rb-node__name" x="12" y="50" fill="var(--ink)">Repair Turn</text>
    <text class="rb-node__hint" x="12" y="74" fill="var(--mute)">feedback in</text>
    <text class="rb-node__hint" x="12" y="92" fill="var(--mute)">public evidence</text>
  </g>

  <g class="rb-node rb-stage rb-stage--4" transform="translate(558,58)">
    <rect width="148" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="rb-node__idx" x="12" y="26" fill="var(--accent)">04</text>
    <text class="rb-node__name" x="12" y="50" fill="var(--ink)">Re-check</text>
    <text class="rb-node__hint" x="12" y="74" fill="var(--mute)">plan still binds</text>
    <text class="rb-node__hint" x="12" y="92" fill="var(--mute)">submit again</text>
  </g>

  <g class="rb-node rb-stage rb-stage--5" transform="translate(734,58)">
    <rect
      width="126"
      height="104"
      rx="1"
      fill="var(--soft)"
      stroke="var(--accent)"
      stroke-dasharray="3.5 2.5"
    ></rect>
    <rect width="126" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="rb-node__idx" x="12" y="26" fill="var(--accent)">05</text>
    <text class="rb-node__name" x="12" y="50" fill="var(--ink)">Stop loop</text>
    <text class="rb-node__hint" x="12" y="74" fill="var(--mute)">cap exhausted</text>
    <text class="rb-node__hint" x="12" y="92" fill="var(--mute)">no self-trust</text>
  </g>

  <text class="rb-foot rb-stage rb-stage--5" x="8" y="198" fill="var(--mute)">
    Self-check helps repair; exhausted budget ends the loop — it never grants infinite trust.
  </text>
</svg>

<style>
  .rb-flow {
    font-family: var(--sans);
  }
  .rb-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
  }
  .rb-node__idx {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .rb-node__name {
    font-family: var(--serif);
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .rb-node__hint {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.03em;
  }
  .rb-foot {
    font-family: var(--serif);
    font-size: 13px;
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .rb-stage {
      opacity: 0;
      animation: rb-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .rb-stage--0 {
      animation-delay: 0.04s;
    }
    .rb-stage--1 {
      animation-delay: 0.12s;
    }
    .rb-stage--2 {
      animation-delay: 0.24s;
    }
    .rb-stage--3 {
      animation-delay: 0.36s;
    }
    .rb-stage--4 {
      animation-delay: 0.48s;
    }
    .rb-stage--5 {
      animation-delay: 0.6s;
    }
    @keyframes rb-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .rb-stage {
      opacity: 1;
      animation: none;
    }
  }
</style>
