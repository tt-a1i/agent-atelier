---
/**
 * §04 flow — AutonomousLoopBudget: three hard caps that dominate policy.
 */
---

<svg
  class="bl-flow"
  viewBox="0 0 868 248"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <text class="bl-kicker bl-stage bl-stage--0" x="8" y="20" fill="var(--accent)">
    FLOW · AUTONOMOUS LOOP BUDGET · ENFORCECAPS DOMINATES
  </text>
  <line class="bl-stage bl-stage--0" x1="8" y1="34" x2="860" y2="34" stroke="var(--hair)" stroke-width="1"></line>
  <g class="bl-col bl-stage bl-stage--1" transform="translate(8,52)">
    <rect width="272" height="168" rx="1" fill="var(--bg)" stroke="var(--accent)"></rect>
    <rect width="272" height="2" fill="var(--accent)"></rect>
    <text class="bl-col__idx" x="14" y="28" fill="var(--accent)">A · ATTEMPTS</text>
    <text class="bl-col__title" x="14" y="56" fill="var(--ink)">maxAttempts</text>
    <text class="bl-col__line" x="14" y="90" fill="var(--mute)">TaskRun outer loop</text>
    <text class="bl-col__line" x="14" y="114" fill="var(--mute)">checked before/after</text>
    <text class="bl-col__line" x="14" y="148" fill="var(--ink)">each runTaskOnce</text>
  </g>
  <g class="bl-col bl-stage bl-stage--2" transform="translate(298,52)">
    <rect width="272" height="168" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="272" height="2" fill="var(--accent)" opacity="0.65"></rect>
    <text class="bl-col__idx" x="14" y="28" fill="var(--accent)">B · RUNTIME STEPS</text>
    <text class="bl-col__title" x="14" y="56" fill="var(--ink)">maxRuntimeSteps</text>
    <text class="bl-col__line" x="14" y="90" fill="var(--mute)">sum across Attempts</text>
    <text class="bl-col__line" x="14" y="114" fill="var(--mute)">checked after Attempt</text>
    <text class="bl-col__line" x="14" y="148" fill="var(--ink)">not per-Attempt only</text>
  </g>
  <g class="bl-col bl-stage bl-stage--3" transform="translate(588,52)">
    <rect width="272" height="168" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="272" height="2" fill="var(--accent)" opacity="0.4"></rect>
    <text class="bl-col__idx" x="14" y="28" fill="var(--accent)">C · WALL TIME</text>
    <text class="bl-col__title" x="14" y="56" fill="var(--ink)">maxWallTimeMs</text>
    <text class="bl-col__line" x="14" y="90" fill="var(--mute)">TaskRun loop clock</text>
    <text class="bl-col__line" x="14" y="114" fill="var(--mute)">before/after Attempt</text>
    <text class="bl-col__line" x="14" y="148" fill="var(--ink)">≠ new-process reset</text>
  </g>
</svg>

<style>
  .bl-flow { font-family: var(--sans); }
  .bl-kicker { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.1em; }
  .bl-col__idx { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; }
  .bl-col__title { font-family: var(--serif); font-size: 16px; font-weight: 600; letter-spacing: -0.015em; }
  .bl-col__line { font-family: var(--mono); font-size: 11px; letter-spacing: 0.02em; }
  @media (prefers-reduced-motion: no-preference) {
    .bl-stage { opacity: 0; animation: bl-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
    .bl-stage--0 { animation-delay: 0.04s; }
    .bl-stage--1 { animation-delay: 0.16s; }
    .bl-stage--2 { animation-delay: 0.3s; }
    .bl-stage--3 { animation-delay: 0.44s; }
    @keyframes bl-fade { from { opacity: 0; } to { opacity: 1; } }
  }
  @media (prefers-reduced-motion: reduce) {
    .bl-stage { opacity: 1; animation: none; }
  }
</style>
