---
/**
 * §02 protocol — archive-before-placeholder with fail-open diamond.
 * Provider messages may rewrite; RuntimeEvent / Session ledger stay untouched.
 */
---

<svg
  class="ap-flow"
  viewBox="0 0 868 292"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <defs>
    <marker
      id="ap-arrow"
      viewBox="0 0 10 10"
      refX="9"
      refY="5"
      markerWidth="6"
      markerHeight="6"
      orient="auto-start-reverse"
    >
      <path d="M 0 1.5 L 9 5 L 0 8.5 Z" fill="var(--accent)"></path>
    </marker>
  </defs>

  <text class="ap-kicker ap-stage ap-stage--0" x="8" y="20" fill="var(--accent)">
    PROTOCOL · ACTIVE PRUNE · ARCHIVE BEFORE PLACEHOLDER
  </text>
  <line
    class="ap-stage ap-stage--0"
    x1="8"
    y1="34"
    x2="860"
    y2="34"
    stroke="var(--hair)"
    stroke-width="1"
  ></line>

  <!-- Main path connectors -->
  <g class="ap-connectors ap-stage ap-stage--1" stroke="var(--accent)" stroke-width="1.25" fill="none">
    <line x1="156" y1="108" x2="184" y2="108" marker-end="url(#ap-arrow)"></line>
    <line x1="332" y1="108" x2="360" y2="108" marker-end="url(#ap-arrow)"></line>
    <!-- Yes branch -->
    <path d="M 508 108 L 536 108 L 536 78 L 564 78" marker-end="url(#ap-arrow)"></path>
    <!-- No branch -->
    <path d="M 508 108 L 536 108 L 536 148 L 564 148" marker-end="url(#ap-arrow)"></path>
    <!-- Merge to next step -->
    <path d="M 712 78 L 740 78 L 740 108 L 768 108" marker-end="url(#ap-arrow)"></path>
    <path d="M 712 148 L 740 148 L 740 108"></path>
  </g>

  <!-- Ledger untouched (dashed) -->
  <g class="ap-stage ap-stage--1" fill="none" stroke="var(--mute)" stroke-width="1" stroke-dasharray="3.5 2.5">
    <path d="M 82 160 L 82 210 L 820 210"></path>
  </g>
  <text class="ap-ledger ap-stage ap-stage--5" x="96" y="204" fill="var(--mute)">
    RuntimeEvent / Session ledger — unchanged by active prune
  </text>

  <g class="ap-node ap-stage ap-stage--1" transform="translate(8,58)">
    <rect width="148" height="100" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="ap-node__idx" x="12" y="24" fill="var(--accent)">01</text>
    <text class="ap-node__name" x="12" y="48" fill="var(--ink)">Large result</text>
    <text class="ap-node__hint" x="12" y="72" fill="var(--mute)">eligible · this Turn</text>
    <text class="ap-node__hint" x="12" y="90" fill="var(--mute)">completed steps</text>
  </g>

  <g class="ap-node ap-stage ap-stage--2" transform="translate(184,58)">
    <rect width="148" height="100" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="ap-node__idx" x="12" y="24" fill="var(--accent)">02</text>
    <text class="ap-node__name" x="12" y="48" fill="var(--ink)">Hash + size</text>
    <text class="ap-node__hint" x="12" y="72" fill="var(--mute)">bodySha256</text>
    <text class="ap-node__hint" x="12" y="90" fill="var(--mute)">token estimate</text>
  </g>

  <!-- Diamond: Archive succeeds? -->
  <g class="ap-diamond ap-stage ap-stage--3" transform="translate(360,58)">
    <path
      d="M 74 8 L 140 50 L 74 92 L 8 50 Z"
      fill="var(--soft)"
      stroke="var(--accent)"
      stroke-width="1.25"
    ></path>
    <text class="ap-node__idx" x="48" y="42" fill="var(--accent)">03</text>
    <text class="ap-diamond__q" x="32" y="60" fill="var(--ink)">Archive OK?</text>
    <text class="ap-yes" x="118" y="36" fill="var(--accent)">yes</text>
    <text class="ap-no" x="118" y="78" fill="var(--mute)">no</text>
  </g>

  <g class="ap-node ap-stage ap-stage--4" transform="translate(564,48)">
    <rect width="148" height="60" rx="1" fill="var(--soft)" stroke="var(--accent)" stroke-dasharray="3.5 2.5"></rect>
    <text class="ap-node__name" x="12" y="26" fill="var(--ink)">Placeholder</text>
    <text class="ap-node__hint" x="12" y="46" fill="var(--mute)">source-bearing</text>
  </g>

  <g class="ap-node ap-stage ap-stage--4" transform="translate(564,118)">
    <rect width="148" height="60" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <text class="ap-node__name" x="12" y="26" fill="var(--ink)">Keep original</text>
    <text class="ap-node__hint" x="12" y="46" fill="var(--mute)">fail open</text>
  </g>

  <g class="ap-node ap-stage ap-stage--5" transform="translate(768,68)">
    <rect width="92" height="80" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="92" height="2" fill="var(--accent)"></rect>
    <text class="ap-node__idx" x="10" y="24" fill="var(--accent)">04</text>
    <text class="ap-node__name" x="10" y="46" fill="var(--ink)">Next</text>
    <text class="ap-node__hint" x="10" y="66" fill="var(--mute)">provider</text>
  </g>

  <text class="ap-foot ap-stage ap-stage--5" x="8" y="250" fill="var(--mute)">
    Rewrite only the prepareStep messages view. Empty artifactId / thrown archive → keep full payload.
  </text>
  <text class="ap-foot ap-stage ap-stage--5" x="8" y="274" fill="var(--mute)">
    Correctness &gt; token savings. Placeholder ≠ complete evidence.
  </text>
</svg>

<style>
  .ap-flow {
    font-family: var(--sans);
  }
  .ap-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
  }
  .ap-node__idx {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .ap-node__name {
    font-family: var(--serif);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .ap-node__hint {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.03em;
  }
  .ap-diamond__q {
    font-family: var(--serif);
    font-size: 12px;
    font-weight: 600;
  }
  .ap-yes,
  .ap-no {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.04em;
  }
  .ap-ledger {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.02em;
  }
  .ap-foot {
    font-family: var(--serif);
    font-size: 12.5px;
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ap-stage {
      opacity: 0;
      animation: ap-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .ap-stage--0 {
      animation-delay: 0.04s;
    }
    .ap-stage--1 {
      animation-delay: 0.12s;
    }
    .ap-stage--2 {
      animation-delay: 0.24s;
    }
    .ap-stage--3 {
      animation-delay: 0.36s;
    }
    .ap-stage--4 {
      animation-delay: 0.48s;
    }
    .ap-stage--5 {
      animation-delay: 0.6s;
    }
    @keyframes ap-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ap-stage {
      opacity: 1;
      animation: none;
    }
  }
</style>
