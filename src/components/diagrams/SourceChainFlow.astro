---
/**
 * §02 flow — source-bearing chain from tool result to later consumers.
 */
---

<svg
  class="sc-flow"
  viewBox="0 0 868 220"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <defs>
    <marker id="sc-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 1.5 L 9 5 L 0 8.5 Z" fill="var(--accent)"></path>
    </marker>
  </defs>
  <text class="sc-kicker sc-stage sc-stage--0" x="8" y="20" fill="var(--accent)">
    FLOW · SOURCE CHAIN · OBSERVE WITHOUT ERASING
  </text>
  <line class="sc-stage sc-stage--0" x1="8" y1="34" x2="860" y2="34" stroke="var(--hair)" stroke-width="1"></line>
  <g class="sc-connectors sc-stage sc-stage--1" stroke="var(--accent)" stroke-width="1.25" fill="none">
    <line x1="198" y1="110" x2="226" y2="110" marker-end="url(#sc-arrow)"></line>
    <line x1="414" y1="110" x2="442" y2="110" marker-end="url(#sc-arrow)"></line>
    <line x1="630" y1="110" x2="658" y2="110" marker-end="url(#sc-arrow)"></line>
  </g>
  <g class="sc-node sc-stage sc-stage--1" transform="translate(8,58)">
    <rect width="190" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="190" height="2" fill="var(--accent)"></rect>
    <text class="sc-node__idx" x="12" y="26" fill="var(--accent)">01</text>
    <text class="sc-node__name" x="12" y="50" fill="var(--ink)">RuntimeEvent</text>
    <text class="sc-node__hint" x="12" y="74" fill="var(--mute)">call / response</text>
    <text class="sc-node__hint" x="12" y="92" fill="var(--mute)">canonical fact</text>
  </g>
  <g class="sc-node sc-stage sc-stage--2" transform="translate(226,58)">
    <rect width="188" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="188" height="2" fill="var(--accent)"></rect>
    <text class="sc-node__idx" x="12" y="26" fill="var(--accent)">02</text>
    <text class="sc-node__name" x="12" y="50" fill="var(--ink)">Artifact ref</text>
    <text class="sc-node__hint" x="12" y="74" fill="var(--mute)">raw bytes loc</text>
    <text class="sc-node__hint" x="12" y="92" fill="var(--mute)">checksum</text>
  </g>
  <g class="sc-node sc-stage sc-stage--3" transform="translate(442,58)">
    <rect width="188" height="104" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="188" height="2" fill="var(--accent)" opacity="0.7"></rect>
    <text class="sc-node__idx" x="12" y="26" fill="var(--accent)">03</text>
    <text class="sc-node__name" x="12" y="50" fill="var(--ink)">Turn Evidence</text>
    <text class="sc-node__hint" x="12" y="74" fill="var(--mute)">source-bearing</text>
    <text class="sc-node__hint" x="12" y="92" fill="var(--mute)">bounded observe</text>
  </g>
  <g class="sc-node sc-stage sc-stage--4" transform="translate(658,58)">
    <rect width="202" height="104" rx="1" fill="var(--soft)" stroke="var(--accent)" stroke-dasharray="3.5 2.5"></rect>
    <rect width="202" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="sc-node__idx" x="12" y="26" fill="var(--accent)">04</text>
    <text class="sc-node__name" x="12" y="50" fill="var(--ink)">Later consumer</text>
    <text class="sc-node__hint" x="12" y="74" fill="var(--mute)">next Turn / §05</text>
    <text class="sc-node__hint" x="12" y="92" fill="var(--mute)">fetch raw if needed</text>
  </g>
  <text class="sc-foot sc-stage sc-stage--4" x="8" y="198" fill="var(--mute)">
    Evidence points at sources; it never replaces Runtime terminal status or official verifiers.
  </text>
</svg>

<style>
  .sc-flow { font-family: var(--sans); }
  .sc-kicker { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.1em; }
  .sc-node__idx { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; }
  .sc-node__name { font-family: var(--serif); font-size: 14.5px; font-weight: 600; letter-spacing: -0.015em; }
  .sc-node__hint { font-family: var(--mono); font-size: 10px; letter-spacing: 0.03em; }
  .sc-foot { font-family: var(--serif); font-size: 13px; font-style: italic; }
  @media (prefers-reduced-motion: no-preference) {
    .sc-stage { opacity: 0; animation: sc-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
    .sc-stage--0 { animation-delay: 0.04s; }
    .sc-stage--1 { animation-delay: 0.12s; }
    .sc-stage--2 { animation-delay: 0.26s; }
    .sc-stage--3 { animation-delay: 0.38s; }
    .sc-stage--4 { animation-delay: 0.5s; }
    @keyframes sc-fade { from { opacity: 0; } to { opacity: 1; } }
  }
  @media (prefers-reduced-motion: reduce) {
    .sc-stage { opacity: 1; animation: none; }
  }
</style>
