---
/**
 * §01 protocol — model ↔ tool step loop condensed; tools pause model idle watchdog.
 */
---

<svg
  class="mtl-flow"
  viewBox="0 0 868 300"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <text class="mtl-kicker mtl-stage mtl-stage--0" x="8" y="20" fill="var(--accent)">
    PROTOCOL · MODEL ↔ TOOL LOOP · PERSIST PER STEP · ONE TERMINAL
  </text>
  <line class="mtl-stage mtl-stage--0" x1="8" y1="34" x2="860" y2="34" stroke="var(--hair)" stroke-width="1"
  ></line>

  <g class="mtl-stage mtl-stage--1" transform="translate(8,52)">
    <rect width="160" height="120" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <text class="mtl-idx" x="12" y="26" fill="var(--accent)">1–2</text>
    <text class="mtl-title" x="12" y="52" fill="var(--ink)">Begin</text>
    <text class="mtl-line" x="12" y="80" fill="var(--mute)">Kernel → Run</text>
    <text class="mtl-line" x="12" y="102" fill="var(--mute)">Runner → Flow</text>
  </g>
  <path class="mtl-stage mtl-stage--1" d="M176 112 H196" stroke="var(--accent)" stroke-width="1.5" fill="none" marker-end="url(#mtl-arrow)"></path>

  <g class="mtl-stage mtl-stage--2" transform="translate(204,52)">
    <rect width="160" height="120" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <text class="mtl-idx" x="12" y="26" fill="var(--accent)">3</text>
    <text class="mtl-title" x="12" y="52" fill="var(--ink)">streamText</text>
    <text class="mtl-line" x="12" y="80" fill="var(--mute)">think / text</text>
    <text class="mtl-line" x="12" y="102" fill="var(--mute)">tool call</text>
  </g>
  <path class="mtl-stage mtl-stage--2" d="M372 112 H392" stroke="var(--accent)" stroke-width="1.5" fill="none" marker-end="url(#mtl-arrow)"></path>

  <g class="mtl-stage mtl-stage--3" transform="translate(400,52)">
    <rect width="180" height="120" rx="1" fill="var(--soft)" stroke="var(--accent)"></rect>
    <rect width="180" height="2" fill="var(--accent)"></rect>
    <text class="mtl-idx" x="12" y="26" fill="var(--accent)">4</text>
    <text class="mtl-title" x="12" y="52" fill="var(--ink)">ToolRuntime</text>
    <text class="mtl-line" x="12" y="80" fill="var(--mute)">execute / guard</text>
    <text class="mtl-line" x="12" y="102" fill="var(--ink)">pause idle WD</text>
  </g>
  <path class="mtl-stage mtl-stage--3" d="M588 112 H608" stroke="var(--accent)" stroke-width="1.5" fill="none" marker-end="url(#mtl-arrow)"></path>

  <g class="mtl-stage mtl-stage--4" transform="translate(616,52)">
    <rect width="244" height="120" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <text class="mtl-idx" x="12" y="26" fill="var(--accent)">5–6</text>
    <text class="mtl-title" x="12" y="52" fill="var(--ink)">Next step / finish</text>
    <text class="mtl-line" x="12" y="80" fill="var(--mute)">results → model</text>
    <text class="mtl-line" x="12" y="102" fill="var(--mute)">or final text</text>
  </g>

  <path class="mtl-stage mtl-stage--5" d="M490 176 V196" stroke="var(--accent)" stroke-width="1.5" fill="none" marker-end="url(#mtl-arrow)"></path>

  <g class="mtl-stage mtl-stage--5" transform="translate(8,204)">
    <rect width="852" height="76" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <text class="mtl-title" x="16" y="28" fill="var(--ink)">7–8 · Flow emits RuntimeEvents + exactly one terminal → AgentRun commits</text>
    <text class="mtl-line" x="16" y="56" fill="var(--mute)"
      >Persist per-step assistant text/thinking · tool calls carry step IDs · step cap keeps results + continue hint</text
    >
  </g>

  <defs>
    <marker id="mtl-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6" fill="none" stroke="var(--accent)" stroke-width="1.2"></path>
    </marker>
  </defs>
</svg>

<style>
  .mtl-flow { font-family: var(--sans); }
  .mtl-kicker { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.06em; }
  .mtl-idx { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; }
  .mtl-title { font-family: var(--serif); font-size: 15px; font-weight: 600; letter-spacing: -0.015em; }
  .mtl-line { font-family: var(--mono); font-size: 11px; letter-spacing: 0.02em; }
  @media (prefers-reduced-motion: no-preference) {
    .mtl-stage { opacity: 0; animation: mtl-fade 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
    .mtl-stage--0 { animation-delay: 0.04s; }
    .mtl-stage--1 { animation-delay: 0.12s; }
    .mtl-stage--2 { animation-delay: 0.22s; }
    .mtl-stage--3 { animation-delay: 0.32s; }
    .mtl-stage--4 { animation-delay: 0.42s; }
    .mtl-stage--5 { animation-delay: 0.52s; }
    @keyframes mtl-fade { from { opacity: 0; } to { opacity: 1; } }
  }
  @media (prefers-reduced-motion: reduce) {
    .mtl-stage { opacity: 1; animation: none; }
  }
</style>
