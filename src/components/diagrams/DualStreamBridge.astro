---
/**
 * §01 protocol — SessionEvent (legacy/renderer) → AiSdkFlow → RuntimeEvent (canonical).
 */
---

<svg
  class="ds-flow"
  viewBox="0 0 868 268"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <text class="ds-kicker ds-stage ds-stage--0" x="8" y="20" fill="var(--accent)">
    PROTOCOL · DUAL STREAM · LEGACY EMIT → CANONICAL LEDGER
  </text>
  <line class="ds-stage ds-stage--0" x1="8" y1="34" x2="860" y2="34" stroke="var(--hair)" stroke-width="1"
  ></line>

  <g class="ds-stage ds-stage--1" transform="translate(8,52)">
    <rect width="240" height="180" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="240" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="ds-idx" x="14" y="28" fill="var(--accent)">SESSIONEVENT</text>
    <text class="ds-title" x="14" y="56" fill="var(--ink)">Backend emit</text>
    <text class="ds-line" x="14" y="88" fill="var(--mute)">text / thinking</text>
    <text class="ds-line" x="14" y="110" fill="var(--mute)">tool_start / result</text>
    <text class="ds-line" x="14" y="132" fill="var(--mute)">permission / usage</text>
    <text class="ds-line" x="14" y="154" fill="var(--mute)">error / abort / complete</text>
    <text class="ds-line" x="14" y="178" fill="var(--ink)">renderer / legacy</text>
  </g>

  <path class="ds-stage ds-stage--2" d="M260 142 H318" stroke="var(--accent)" stroke-width="1.5" fill="none" marker-end="url(#ds-arrow)"></path>

  <g class="ds-stage ds-stage--2" transform="translate(326,52)">
    <rect width="216" height="180" rx="1" fill="var(--soft)" stroke="var(--accent)"></rect>
    <rect width="216" height="2" fill="var(--accent)"></rect>
    <text class="ds-idx" x="14" y="28" fill="var(--accent)">BRIDGE</text>
    <text class="ds-title" x="14" y="56" fill="var(--ink)">AiSdkFlow</text>
    <text class="ds-line" x="14" y="92" fill="var(--mute)">map → content</text>
    <text class="ds-line" x="14" y="114" fill="var(--mute)">map → actions</text>
    <text class="ds-line" x="14" y="136" fill="var(--mute)">coalesce terminal</text>
    <text class="ds-line" x="14" y="166" fill="var(--ink)">exactly one terminal</text>
  </g>

  <path class="ds-stage ds-stage--3" d="M550 142 H608" stroke="var(--accent)" stroke-width="1.5" fill="none" marker-end="url(#ds-arrow)"></path>

  <g class="ds-stage ds-stage--3" transform="translate(616,52)">
    <rect width="244" height="180" rx="1" fill="var(--bg)" stroke="var(--accent)"></rect>
    <rect width="244" height="2" fill="var(--accent)"></rect>
    <text class="ds-idx" x="14" y="28" fill="var(--accent)">RUNTIMEEVENT</text>
    <text class="ds-title" x="14" y="56" fill="var(--ink)">Canonical log</text>
    <text class="ds-line" x="14" y="88" fill="var(--mute)">model content facts</text>
    <text class="ds-line" x="14" y="110" fill="var(--mute)">tool call / response</text>
    <text class="ds-line" x="14" y="132" fill="var(--mute)">permission / usage</text>
    <text class="ds-line" x="14" y="154" fill="var(--mute)">failure / terminal</text>
    <text class="ds-line" x="14" y="178" fill="var(--ink)">completed replay</text>
  </g>

  <defs>
    <marker id="ds-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0,0 L6,3 L0,6" fill="none" stroke="var(--accent)" stroke-width="1.2"></path>
    </marker>
  </defs>
</svg>

<style>
  .ds-flow { font-family: var(--sans); }
  .ds-kicker { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.06em; }
  .ds-idx { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; }
  .ds-title { font-family: var(--serif); font-size: 16px; font-weight: 600; letter-spacing: -0.015em; }
  .ds-line { font-family: var(--mono); font-size: 11px; letter-spacing: 0.02em; }
  @media (prefers-reduced-motion: no-preference) {
    .ds-stage { opacity: 0; animation: ds-fade 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
    .ds-stage--0 { animation-delay: 0.04s; }
    .ds-stage--1 { animation-delay: 0.14s; }
    .ds-stage--2 { animation-delay: 0.28s; }
    .ds-stage--3 { animation-delay: 0.42s; }
    @keyframes ds-fade { from { opacity: 0; } to { opacity: 1; } }
  }
  @media (prefers-reduced-motion: reduce) {
    .ds-stage { opacity: 1; animation: none; }
  }
</style>
