---
/**
 * §03 flow — rolling checkpoint: prior summary + newly folded → successor coverage.
 */
---

<svg
  class="rc-flow"
  viewBox="0 0 868 268"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <defs>
    <marker
      id="rc-arrow"
      viewBox="0 0 10 10"
      refX="9"
      refY="5"
      markerWidth="6"
      markerHeight="6"
      orient="auto-start-reverse"
    >
      <path d="M 0 1.5 L 9 5 L 0 8.5 Z" fill="var(--accent)"></path>
    </marker>
  </defs>

  <text class="rc-kicker rc-stage rc-stage--0" x="8" y="20" fill="var(--accent)">
    FLOW · ROLLING · DURABLE-BEFORE-REPLACE
  </text>
  <line
    class="rc-stage rc-stage--0"
    x1="8"
    y1="34"
    x2="860"
    y2="34"
    stroke="var(--hair)"
    stroke-width="1"
  ></line>

  <g class="rc-connectors rc-stage rc-stage--1" stroke="var(--accent)" stroke-width="1.25" fill="none">
    <line x1="168" y1="96" x2="188" y2="96" marker-end="url(#rc-arrow)"></line>
    <line x1="168" y1="136" x2="188" y2="116" marker-end="url(#rc-arrow)"></line>
    <line x1="336" y1="106" x2="356" y2="106" marker-end="url(#rc-arrow)"></line>
    <line x1="504" y1="106" x2="528" y2="106" marker-end="url(#rc-arrow)"></line>
    <line x1="656" y1="90" x2="688" y2="78" marker-end="url(#rc-arrow)"></line>
    <line x1="656" y1="122" x2="688" y2="148" stroke-dasharray="3.5 2.5" marker-end="url(#rc-arrow)"></line>
  </g>

  <g class="rc-node rc-stage rc-stage--1" transform="translate(8,54)">
    <rect width="160" height="48" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="160" height="2" fill="var(--accent)"></rect>
    <text class="rc-node__idx" x="10" y="20" fill="var(--accent)">N</text>
    <text class="rc-node__name" x="36" y="26" fill="var(--ink)">Checkpoint N</text>
    <text class="rc-node__hint" x="10" y="42" fill="var(--mute)">coverage[0..k]</text>
  </g>
  <g class="rc-node rc-stage rc-stage--1" transform="translate(8,112)">
    <rect width="160" height="48" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="160" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="rc-node__idx" x="10" y="20" fill="var(--accent)">Δ</text>
    <text class="rc-node__name" x="36" y="26" fill="var(--ink)">Newly folded</text>
    <text class="rc-node__hint" x="10" y="42" fill="var(--mute)">events[k+1..m]</text>
  </g>

  <g class="rc-node rc-stage rc-stage--2" transform="translate(188,54)">
    <rect width="148" height="96" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="rc-node__idx" x="10" y="24" fill="var(--accent)">01</text>
    <text class="rc-node__name" x="10" y="46" fill="var(--ink)">Summarizer</text>
    <text class="rc-node__hint" x="10" y="68" fill="var(--mute)">prior S + Δ</text>
    <text class="rc-node__hint" x="10" y="86" fill="var(--mute)">no re-feed world</text>
  </g>

  <g class="rc-node rc-stage rc-stage--3" transform="translate(356,54)">
    <rect width="148" height="96" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)" opacity="0.7"></rect>
    <text class="rc-node__idx" x="10" y="24" fill="var(--accent)">02</text>
    <text class="rc-node__name" x="10" y="46" fill="var(--ink)">Recompute</text>
    <text class="rc-node__hint" x="10" y="68" fill="var(--mute)">prefix [0..m]</text>
    <text class="rc-node__hint" x="10" y="86" fill="var(--mute)">sourceDigest</text>
  </g>

  <!-- Durable gate diamond -->
  <g class="rc-gate rc-stage rc-stage--4" transform="translate(528,58)">
    <polygon
      points="64,0 128,48 64,96 0,48"
      fill="var(--bg)"
      stroke="var(--accent)"
      stroke-width="1.25"
    ></polygon>
    <text class="rc-node__idx" x="40" y="40" fill="var(--accent)">GATE</text>
    <text class="rc-node__hint" x="28" y="58" fill="var(--ink)">durable</text>
    <text class="rc-node__hint" x="34" y="72" fill="var(--ink)">append?</text>
  </g>

  <g class="rc-node rc-stage rc-stage--5" transform="translate(688,42)">
    <rect width="172" height="52" rx="1" fill="var(--bg)" stroke="var(--accent)"></rect>
    <rect width="172" height="2" fill="var(--accent)"></rect>
    <text class="rc-node__idx" x="10" y="20" fill="var(--accent)">YES</text>
    <text class="rc-node__name" x="48" y="26" fill="var(--ink)">N+1 may replace</text>
    <text class="rc-node__hint" x="10" y="44" fill="var(--mute)">same-request view</text>
  </g>
  <g class="rc-node rc-stage rc-stage--5" transform="translate(688,118)">
    <rect
      width="172"
      height="52"
      rx="1"
      fill="var(--soft)"
      stroke="var(--hair)"
      stroke-dasharray="3.5 2.5"
    ></rect>
    <rect width="172" height="2" fill="var(--accent)" opacity="0.4"></rect>
    <text class="rc-node__idx" x="10" y="20" fill="var(--accent)">NO</text>
    <text class="rc-node__name" x="44" y="26" fill="var(--ink)">Discard candidate</text>
    <text class="rc-node__hint" x="10" y="44" fill="var(--mute)">no false coverage</text>
  </g>

  <text class="rc-foot rc-stage rc-stage--5" x="8" y="198" fill="var(--mute)">
    history_compact_checkpoint_recorded must succeed before replacement enters the provider view.
  </text>
  <text class="rc-foot rc-stage rc-stage--5" x="8" y="222" fill="var(--mute)">
    Same-coverage rewrite needs previousCheckpointId + identical digest/through/counts (CAS).
  </text>
  <text class="rc-foot rc-stage rc-stage--5" x="8" y="246" fill="var(--mute)">
    Prefix / digest failure → reject; never invent a lookalike history.
  </text>
</svg>

<style>
  .rc-flow {
    font-family: var(--sans);
  }
  .rc-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
  }
  .rc-node__idx {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .rc-node__name {
    font-family: var(--serif);
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .rc-node__hint {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.03em;
  }
  .rc-foot {
    font-family: var(--serif);
    font-size: 13px;
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .rc-stage {
      opacity: 0;
      animation: rc-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .rc-stage--0 {
      animation-delay: 0.04s;
    }
    .rc-stage--1 {
      animation-delay: 0.12s;
    }
    .rc-stage--2 {
      animation-delay: 0.26s;
    }
    .rc-stage--3 {
      animation-delay: 0.38s;
    }
    .rc-stage--4 {
      animation-delay: 0.5s;
    }
    .rc-stage--5 {
      animation-delay: 0.62s;
    }
    @keyframes rc-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .rc-stage {
      opacity: 1;
      animation: none;
    }
  }
</style>
