---
/**
 * §06 protocol — scoreAuthority derivation + forbidden staged_patch surface.
 */
---

<svg
  class="sa-flow"
  viewBox="0 0 868 268"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <text class="sa-kicker sa-stage sa-stage--0" x="8" y="20" fill="var(--accent)">
    PROTOCOL · SCORE AUTHORITY · FORBIDDEN PATCH SURFACE
  </text>
  <line
    class="sa-stage sa-stage--0"
    x1="8"
    y1="34"
    x2="860"
    y2="34"
    stroke="var(--hair)"
    stroke-width="1"
  ></line>

  <g class="sa-col sa-stage sa-stage--1" transform="translate(8,52)">
    <rect width="416" height="176" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="416" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="sa-col__idx" x="14" y="28" fill="var(--accent)">EXPORT · AUTHORITY</text>
    <text class="sa-col__title" x="14" y="54" fill="var(--ink)">scoreAuthority()</text>
    <text class="sa-col__line" x="14" y="88" fill="var(--mute)">official_harbor_verifier → official_*</text>
    <text class="sa-col__line" x="14" y="108" fill="var(--mute)">self-check evidence → self_check</text>
    <text class="sa-col__line" x="14" y="128" fill="var(--mute)">else → analysis_only</text>
    <text class="sa-col__line" x="14" y="152" fill="var(--ink)">official_pass needs official_*</text>
  </g>

  <g class="sa-col sa-stage sa-stage--2" transform="translate(444,52)">
    <rect width="416" height="176" rx="1" fill="var(--soft)" stroke="var(--accent)"></rect>
    <rect width="416" height="2" fill="var(--accent)"></rect>
    <text class="sa-col__idx" x="14" y="28" fill="var(--accent)">MANIFEST · PATCH</text>
    <text class="sa-col__title" x="14" y="54" fill="var(--ink)">staged_patch only</text>
    <text class="sa-col__line" x="14" y="88" fill="var(--mute)">repo-relative POSIX · no ..</text>
    <text class="sa-col__line" x="14" y="108" fill="var(--mute)">forbid .git / node_modules / dist</text>
    <text class="sa-col__line" x="14" y="128" fill="var(--mute)">must hit editable sourceRefs</text>
    <text class="sa-col__line" x="14" y="152" fill="var(--ink)">maka-runtime-evidence locked</text>
  </g>

  <text class="sa-foot sa-stage sa-stage--2" x="8" y="254" fill="var(--mute)">
    Admission validation ≠ patch executor. Self-check cannot mint official_pass; evidence plane cannot be patched.
  </text>
</svg>

<style>
  .sa-flow {
    font-family: var(--sans);
  }
  .sa-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
  }
  .sa-col__idx {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
  }
  .sa-col__title {
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .sa-col__line {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.02em;
  }
  .sa-foot {
    font-family: var(--serif);
    font-size: 13px;
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .sa-stage {
      opacity: 0;
      animation: sa-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .sa-stage--0 {
      animation-delay: 0.04s;
    }
    .sa-stage--1 {
      animation-delay: 0.16s;
    }
    .sa-stage--2 {
      animation-delay: 0.3s;
    }
    @keyframes sa-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sa-stage {
      opacity: 1;
      animation: none;
    }
  }
</style>
