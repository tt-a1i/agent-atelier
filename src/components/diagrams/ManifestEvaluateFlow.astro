---
/**
 * §06 flow — restricted change manifest → independent evaluate → accept or rollback.
 */
---

<svg
  class="me-flow"
  viewBox="0 0 868 220"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <defs>
    <marker
      id="me-arrow"
      viewBox="0 0 10 10"
      refX="9"
      refY="5"
      markerWidth="6"
      markerHeight="6"
      orient="auto-start-reverse"
    >
      <path d="M 0 1.5 L 9 5 L 0 8.5 Z" fill="var(--accent)"></path>
    </marker>
  </defs>

  <text class="me-kicker me-stage me-stage--0" x="8" y="20" fill="var(--accent)">
    FLOW · MANIFEST → EVALUATE → ACCEPT / ROLLBACK
  </text>
  <line
    class="me-stage me-stage--0"
    x1="8"
    y1="34"
    x2="860"
    y2="34"
    stroke="var(--hair)"
    stroke-width="1"
  ></line>

  <g class="me-connectors me-stage me-stage--1" stroke="var(--accent)" stroke-width="1.25" fill="none">
    <line x1="178" y1="110" x2="206" y2="110" marker-end="url(#me-arrow)"></line>
    <line x1="354" y1="110" x2="382" y2="110" marker-end="url(#me-arrow)"></line>
    <line x1="530" y1="110" x2="558" y2="110" marker-end="url(#me-arrow)"></line>
    <line x1="706" y1="110" x2="734" y2="110" marker-end="url(#me-arrow)"></line>
  </g>

  <g class="me-node me-stage me-stage--1" transform="translate(8,58)">
    <rect width="170" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="170" height="2" fill="var(--accent)"></rect>
    <text class="me-node__idx" x="12" y="26" fill="var(--accent)">01</text>
    <text class="me-node__name" x="12" y="50" fill="var(--ink)">Target snap</text>
    <text class="me-node__hint" x="12" y="74" fill="var(--mute)">allowed surface</text>
    <text class="me-node__hint" x="12" y="92" fill="var(--mute)">sourceRefs</text>
  </g>

  <g class="me-node me-stage me-stage--2" transform="translate(206,58)">
    <rect width="148" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="me-node__idx" x="12" y="26" fill="var(--accent)">02</text>
    <text class="me-node__name" x="12" y="50" fill="var(--ink)">Manifest</text>
    <text class="me-node__hint" x="12" y="74" fill="var(--mute)">restricted patch</text>
    <text class="me-node__hint" x="12" y="92" fill="var(--mute)">AHE proposes</text>
  </g>

  <g class="me-node me-stage me-stage--3" transform="translate(382,58)">
    <rect width="148" height="104" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)" opacity="0.7"></rect>
    <text class="me-node__idx" x="12" y="26" fill="var(--accent)">03</text>
    <text class="me-node__name" x="12" y="50" fill="var(--ink)">Independent</text>
    <text class="me-node__hint" x="12" y="74" fill="var(--mute)">eval harness</text>
    <text class="me-node__hint" x="12" y="92" fill="var(--mute)">≠ proposer</text>
  </g>

  <g class="me-node me-stage me-stage--4" transform="translate(558,58)">
    <rect width="148" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="me-node__idx" x="12" y="26" fill="var(--accent)">04</text>
    <text class="me-node__name" x="12" y="50" fill="var(--ink)">Accept?</text>
    <text class="me-node__hint" x="12" y="74" fill="var(--mute)">baseline vs cand</text>
    <text class="me-node__hint" x="12" y="92" fill="var(--mute)">falsifiable</text>
  </g>

  <g class="me-node me-stage me-stage--5" transform="translate(734,58)">
    <rect
      width="126"
      height="104"
      rx="1"
      fill="var(--soft)"
      stroke="var(--accent)"
      stroke-dasharray="3.5 2.5"
    ></rect>
    <rect width="126" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="me-node__idx" x="12" y="26" fill="var(--accent)">05</text>
    <text class="me-node__name" x="12" y="50" fill="var(--ink)">Lineage</text>
    <text class="me-node__hint" x="12" y="74" fill="var(--mute)">keep or roll</text>
    <text class="me-node__hint" x="12" y="92" fill="var(--mute)">outside Runtime</text>
  </g>

  <text class="me-foot me-stage me-stage--5" x="8" y="198" fill="var(--mute)">
    Evolution plane proposes; independent evaluation decides — Runtime stays the experience recorder.
  </text>
</svg>

<style>
  .me-flow {
    font-family: var(--sans);
  }
  .me-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
  }
  .me-node__idx {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .me-node__name {
    font-family: var(--serif);
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .me-node__hint {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.03em;
  }
  .me-foot {
    font-family: var(--serif);
    font-size: 13px;
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .me-stage {
      opacity: 0;
      animation: me-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .me-stage--0 {
      animation-delay: 0.04s;
    }
    .me-stage--1 {
      animation-delay: 0.12s;
    }
    .me-stage--2 {
      animation-delay: 0.24s;
    }
    .me-stage--3 {
      animation-delay: 0.36s;
    }
    .me-stage--4 {
      animation-delay: 0.48s;
    }
    .me-stage--5 {
      animation-delay: 0.6s;
    }
    @keyframes me-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .me-stage {
      opacity: 1;
      animation: none;
    }
  }
</style>
