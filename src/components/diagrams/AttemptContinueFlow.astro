---
/**
 * §04 flow — bounded Attempt ends → policy decides continue / retry / stop / abort.
 */
---

<svg
  class="ac-flow"
  viewBox="0 0 868 220"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <defs>
    <marker
      id="ac-arrow"
      viewBox="0 0 10 10"
      refX="9"
      refY="5"
      markerWidth="6"
      markerHeight="6"
      orient="auto-start-reverse"
    >
      <path d="M 0 1.5 L 9 5 L 0 8.5 Z" fill="var(--accent)"></path>
    </marker>
  </defs>

  <text class="ac-kicker ac-stage ac-stage--0" x="8" y="20" fill="var(--accent)">
    FLOW · ATTEMPT SLICE → POLICY GATE → NEXT WORK
  </text>
  <line
    class="ac-stage ac-stage--0"
    x1="8"
    y1="34"
    x2="860"
    y2="34"
    stroke="var(--hair)"
    stroke-width="1"
  ></line>

  <g class="ac-connectors ac-stage ac-stage--1" stroke="var(--accent)" stroke-width="1.25" fill="none">
    <line x1="178" y1="110" x2="206" y2="110" marker-end="url(#ac-arrow)"></line>
    <line x1="354" y1="110" x2="382" y2="110" marker-end="url(#ac-arrow)"></line>
    <line x1="530" y1="110" x2="558" y2="110" marker-end="url(#ac-arrow)"></line>
    <line x1="706" y1="110" x2="734" y2="110" marker-end="url(#ac-arrow)"></line>
  </g>

  <g class="ac-node ac-stage ac-stage--1" transform="translate(8,58)">
    <rect width="170" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="170" height="2" fill="var(--accent)"></rect>
    <text class="ac-node__idx" x="12" y="26" fill="var(--accent)">01</text>
    <text class="ac-node__name" x="12" y="50" fill="var(--ink)">runTaskOnce</text>
    <text class="ac-node__hint" x="12" y="74" fill="var(--mute)">new Attempt</text>
    <text class="ac-node__hint" x="12" y="92" fill="var(--mute)">bounded Runtime</text>
  </g>

  <g class="ac-node ac-stage ac-stage--2" transform="translate(206,58)">
    <rect width="148" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="ac-node__idx" x="12" y="26" fill="var(--accent)">02</text>
    <text class="ac-node__name" x="12" y="50" fill="var(--ink)">Attempt ends</text>
    <text class="ac-node__hint" x="12" y="74" fill="var(--mute)">cap · park</text>
    <text class="ac-node__hint" x="12" y="92" fill="var(--mute)">fail · cancel</text>
  </g>

  <g class="ac-node ac-stage ac-stage--3" transform="translate(382,58)">
    <rect width="148" height="104" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)" opacity="0.7"></rect>
    <text class="ac-node__idx" x="12" y="26" fill="var(--accent)">03</text>
    <text class="ac-node__name" x="12" y="50" fill="var(--ink)">Append TaskEvt</text>
    <text class="ac-node__hint" x="12" y="74" fill="var(--mute)">progress</text>
    <text class="ac-node__hint" x="12" y="92" fill="var(--mute)">decision refs</text>
  </g>

  <g class="ac-node ac-stage ac-stage--4" transform="translate(558,58)">
    <rect width="148" height="104" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="ac-node__idx" x="12" y="26" fill="var(--accent)">04</text>
    <text class="ac-node__name" x="12" y="50" fill="var(--ink)">Policy gate</text>
    <text class="ac-node__hint" x="12" y="74" fill="var(--mute)">continue/retry</text>
    <text class="ac-node__hint" x="12" y="92" fill="var(--mute)">stop / abort</text>
  </g>

  <g class="ac-node ac-stage ac-stage--5" transform="translate(734,58)">
    <rect
      width="126"
      height="104"
      rx="1"
      fill="var(--soft)"
      stroke="var(--accent)"
      stroke-dasharray="3.5 2.5"
    ></rect>
    <rect width="126" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="ac-node__idx" x="12" y="26" fill="var(--accent)">05</text>
    <text class="ac-node__name" x="12" y="50" fill="var(--ink)">Next view</text>
    <text class="ac-node__hint" x="12" y="74" fill="var(--mute)">project ledger</text>
    <text class="ac-node__hint" x="12" y="92" fill="var(--mute)">≠ revive IP</text>
  </g>

  <text class="ac-foot ac-stage ac-stage--5" x="8" y="198" fill="var(--mute)">
    Continue means a new Attempt — not resurrecting an exited Invocation or tool process.
  </text>
</svg>

<style>
  .ac-flow {
    font-family: var(--sans);
  }
  .ac-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
  }
  .ac-node__idx {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  .ac-node__name {
    font-family: var(--serif);
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .ac-node__hint {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.03em;
  }
  .ac-foot {
    font-family: var(--serif);
    font-size: 13px;
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ac-stage {
      opacity: 0;
      animation: ac-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .ac-stage--0 {
      animation-delay: 0.04s;
    }
    .ac-stage--1 {
      animation-delay: 0.12s;
    }
    .ac-stage--2 {
      animation-delay: 0.24s;
    }
    .ac-stage--3 {
      animation-delay: 0.36s;
    }
    .ac-stage--4 {
      animation-delay: 0.48s;
    }
    .ac-stage--5 {
      animation-delay: 0.6s;
    }
    @keyframes ac-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ac-stage {
      opacity: 1;
      animation: none;
    }
  }
</style>
