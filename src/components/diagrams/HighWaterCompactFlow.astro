---
/**
 * §03 flow figure — high-water fold → durable checkpoint → replay gate.
 */
---

<svg
  class="high-water"
  viewBox="0 0 868 228"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <defs>
    <marker
      id="hw-arrow"
      viewBox="0 0 10 10"
      refX="9"
      refY="5"
      markerWidth="6"
      markerHeight="6"
      orient="auto-start-reverse"
    >
      <path d="M 0 1.5 L 9 5 L 0 8.5 Z" fill="var(--accent)"></path>
    </marker>
  </defs>

  <text class="hw-kicker hw-stage hw-stage--0" x="8" y="20" fill="var(--accent)">
    FLOW · HIGH WATER → FOLD → DURABLE → REPLAY
  </text>
  <line
    class="hw-stage hw-stage--0"
    x1="8"
    y1="34"
    x2="860"
    y2="34"
    stroke="var(--hair)"
    stroke-width="1"
  ></line>

  <g class="hw-connectors hw-stage hw-stage--1" stroke="var(--accent)" stroke-width="1.25" fill="none">
    <line x1="178" y1="110" x2="206" y2="110" marker-end="url(#hw-arrow)"></line>
    <line x1="354" y1="110" x2="382" y2="110" marker-end="url(#hw-arrow)"></line>
    <line x1="530" y1="110" x2="558" y2="110" marker-end="url(#hw-arrow)"></line>
    <line x1="706" y1="110" x2="734" y2="110" marker-end="url(#hw-arrow)"></line>
  </g>

  <g class="hw-node hw-stage hw-stage--1" transform="translate(8,58)">
    <rect width="170" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="170" height="2" fill="var(--accent)"></rect>
    <text class="hw-node__idx" x="12" y="26" fill="var(--accent)">01</text>
    <text class="hw-node__name" x="12" y="50" fill="var(--ink)">Past high water</text>
    <text class="hw-node__hint" x="12" y="74" fill="var(--mute)">budget policy</text>
    <text class="hw-node__hint" x="12" y="92" fill="var(--mute)">select fold prefix</text>
  </g>

  <g class="hw-node hw-stage hw-stage--2" transform="translate(206,58)">
    <rect width="148" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="hw-node__idx" x="12" y="26" fill="var(--accent)">02</text>
    <text class="hw-node__name" x="12" y="50" fill="var(--ink)">LLM summary</text>
    <text class="hw-node__hint" x="12" y="74" fill="var(--mute)">value only</text>
    <text class="hw-node__hint" x="12" y="92" fill="var(--mute)">not authority</text>
  </g>

  <g class="hw-node hw-stage hw-stage--3" transform="translate(382,58)">
    <rect width="148" height="104" rx="1" fill="var(--bg)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)"></rect>
    <text class="hw-node__idx" x="12" y="26" fill="var(--accent)">03</text>
    <text class="hw-node__name" x="12" y="50" fill="var(--ink)">Durable append</text>
    <text class="hw-node__hint" x="12" y="74" fill="var(--mute)">checkpoint</text>
    <text class="hw-node__hint" x="12" y="92" fill="var(--mute)">recorded event</text>
  </g>

  <g class="hw-node hw-stage hw-stage--4" transform="translate(558,58)">
    <rect width="148" height="104" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="148" height="2" fill="var(--accent)" opacity="0.7"></rect>
    <text class="hw-node__idx" x="12" y="26" fill="var(--accent)">04</text>
    <text class="hw-node__name" x="12" y="50" fill="var(--ink)">Coverage gate</text>
    <text class="hw-node__hint" x="12" y="74" fill="var(--mute)">digest + prefix</text>
    <text class="hw-node__hint" x="12" y="92" fill="var(--mute)">current policy</text>
  </g>

  <g class="hw-node hw-stage hw-stage--5" transform="translate(734,58)">
    <rect
      width="126"
      height="104"
      rx="1"
      fill="var(--soft)"
      stroke="var(--accent)"
      stroke-dasharray="3.5 2.5"
    ></rect>
    <rect width="126" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="hw-node__idx" x="12" y="26" fill="var(--accent)">05</text>
    <text class="hw-node__name" x="12" y="50" fill="var(--ink)">Replay</text>
    <text class="hw-node__hint" x="12" y="74" fill="var(--mute)">+ raw tail</text>
    <text class="hw-node__hint" x="12" y="92" fill="var(--mute)">into request</text>
  </g>

  <text class="hw-foot hw-stage hw-stage--5" x="8" y="188" fill="var(--mute)">
    Token thresholds = Current policy knobs (env-overridable) — not protocol constants.
  </text>
  <text class="hw-foot hw-stage hw-stage--5" x="8" y="208" fill="var(--mute)">
    No durability → no replacement. Fail open to safe source-derived context, never invented summary.
  </text>
</svg>

<style>
  .high-water {
    font-family: var(--sans);
  }

  .hw-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
  }

  .hw-node__idx {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .hw-node__name {
    font-family: var(--serif);
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .hw-node__hint {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.03em;
  }

  .hw-foot {
    font-family: var(--serif);
    font-size: 13px;
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hw-stage {
      opacity: 0;
      animation: hw-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .hw-stage--0 {
      animation-delay: 0.04s;
    }
    .hw-stage--1 {
      animation-delay: 0.12s;
    }
    .hw-stage--2 {
      animation-delay: 0.24s;
    }
    .hw-stage--3 {
      animation-delay: 0.36s;
    }
    .hw-stage--4 {
      animation-delay: 0.48s;
    }
    .hw-stage--5 {
      animation-delay: 0.6s;
    }

    @keyframes hw-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hw-stage {
      opacity: 1;
      animation: none;
    }
  }
</style>
