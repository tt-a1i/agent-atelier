---
/**
 * §02 protocol — Active prune (same Turn) vs Stale prune (prior history).
 */
---

<svg
  class="avs-flow"
  viewBox="0 0 868 248"
  xmlns="http://www.w3.org/2000/svg"
  role="presentation"
  focusable="false"
>
  <text class="avs-kicker avs-stage avs-stage--0" x="8" y="20" fill="var(--accent)">
    PROTOCOL · TWO PRUNE POLICIES · DO NOT COLLAPSE
  </text>
  <line
    class="avs-stage avs-stage--0"
    x1="8"
    y1="34"
    x2="860"
    y2="34"
    stroke="var(--hair)"
    stroke-width="1"
  ></line>

  <g class="avs-col avs-stage avs-stage--1" transform="translate(8,52)">
    <rect width="416" height="168" rx="1" fill="var(--bg)" stroke="var(--accent)"></rect>
    <rect width="416" height="2" fill="var(--accent)"></rect>
    <text class="avs-col__idx" x="16" y="28" fill="var(--accent)">ACTIVE · SAME TURN</text>
    <text class="avs-col__title" x="16" y="56" fill="var(--ink)">prepareStep request shaping</text>
    <text class="avs-col__line" x="16" y="88" fill="var(--mute)">When: between steps, current Turn</text>
    <text class="avs-col__line" x="16" y="110" fill="var(--mute)">Target: just-finished large results</text>
    <text class="avs-col__line" x="16" y="132" fill="var(--mute)">Gate: archive → placeholder or keep</text>
    <text class="avs-col__line" x="16" y="160" fill="var(--ink)">Risk if confused: rewrite mid-Turn history</text>
  </g>

  <g class="avs-col avs-stage avs-stage--2" transform="translate(444,52)">
    <rect width="416" height="168" rx="1" fill="var(--soft)" stroke="var(--hair)"></rect>
    <rect width="416" height="2" fill="var(--accent)" opacity="0.55"></rect>
    <text class="avs-col__idx" x="16" y="28" fill="var(--accent)">STALE · PRIOR HISTORY</text>
    <text class="avs-col__title" x="16" y="56" fill="var(--ink)">replay materialization policy</text>
    <text class="avs-col__line" x="16" y="88" fill="var(--mute)">When: building prior messages</text>
    <text class="avs-col__line" x="16" y="110" fill="var(--mute)">Target: old oversized tool results</text>
    <text class="avs-col__line" x="16" y="132" fill="var(--mute)">Separate path from active prune</text>
    <text class="avs-col__line" x="16" y="160" fill="var(--ink)">Risk if confused: miss current pressure</text>
  </g>
</svg>

<style>
  .avs-flow {
    font-family: var(--sans);
  }
  .avs-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
  }
  .avs-col__idx {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
  }
  .avs-col__title {
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .avs-col__line {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.02em;
  }

  @media (prefers-reduced-motion: no-preference) {
    .avs-stage {
      opacity: 0;
      animation: avs-fade 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    .avs-stage--0 {
      animation-delay: 0.04s;
    }
    .avs-stage--1 {
      animation-delay: 0.16s;
    }
    .avs-stage--2 {
      animation-delay: 0.32s;
    }
    @keyframes avs-fade {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .avs-stage {
      opacity: 1;
      animation: none;
    }
  }
</style>
