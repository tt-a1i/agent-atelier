---
import ReportLayout from "../layouts/ReportLayout.astro";
import { chapterNavItems } from "../lib/chapters";
import { localePath, type Locale } from "../lib/i18n";
import {
  HISTORY_PAGE_SIZE,
  hasMakaHistorySnapshot,
  listPrAreas,
  listPrAuthors,
  loadMeta,
  loadPrs,
  prAreaChips,
} from "../lib/maka-history";

interface Props {
  locale?: Locale;
}

const { locale = "zh" } = Astro.props;
const nav = chapterNavItems(locale);
const base = localePath(locale, "history");

const ready = hasMakaHistorySnapshot();
const meta = ready ? loadMeta() : null;
const allPrs = ready ? loadPrs() : [];
const authors = ready ? listPrAuthors(allPrs) : [];
const areas = ready ? listPrAreas(allPrs) : [];

/** Compact rows for client-side filter/pagination (static-hosting safe). */
const prIndex = allPrs.map((pr) => ({
  n: pr.number,
  t: pr.title,
  a: pr.author,
  m: pr.mergedAt,
  areas: prAreaChips(pr, 12),
}));

const dateLocale = locale === "en" ? "en-US" : "zh-CN";

const copy =
  locale === "en"
    ? {
        title: "History · Maka lineage · Agent Atelier",
        description: "Merged PR timeline for maka-agent (pinned snapshot, PR-first).",
        h1: "Maka lineage",
        sub: "Browse development by merged PR; member commits nest on detail pages. Cognitive chapters stay milestone-shaped — this track is the full archive.",
        wip: "Filters (area / author / time / search) run client-side against the pin (static-safe). First-parent / full-DAG advanced views remain WIP — not complete.",
        empty: "No data/maka-history/ snapshot found. Run npm run history:ingest first.",
        prev: "← Prev",
        next: "Next →",
        pager: "Pagination",
        filters: "Filters",
        area: "Area",
        author: "Author",
        range: "Time",
        search: "Search",
        apply: "Apply",
        reset: "Reset",
        all: "All",
        d30: "30 days",
        d90: "90 days",
        year: "1 year",
        showing: "Showing",
        of: "of",
        prs: "PRs",
        filtered: "(filtered)",
        none: "No PRs match these filters.",
        loading: "Loading timeline…",
      }
    : {
        title: "History · Maka 演进轨 · Agent Atelier",
        description: "Maka 仓库合并 PR 时间线（pinned snapshot，PR-first）。",
        h1: "Maka 演进史",
        sub: "默认按已合并 PR 浏览发展链路；成员 commit 嵌套在详情页。认知轨章节保持里程碑叙事，这里提供完整可追溯档案。",
        wip: "area / author / time / search 在客户端对 pin 筛选（静态托管可用）。first-parent / full-DAG 高级视图仍未上线——勿当作完成。",
        empty: "尚未找到 data/maka-history/ 快照。请先运行 npm run history:ingest。",
        prev: "← 上一页",
        next: "下一页 →",
        pager: "分页",
        filters: "筛选",
        area: "区域",
        author: "作者",
        range: "时间",
        search: "搜索",
        apply: "应用",
        reset: "重置",
        all: "全部",
        d30: "30 天",
        d90: "90 天",
        year: "一年",
        showing: "显示",
        of: "/",
        prs: "条 PR",
        filtered: "（已筛选）",
        none: "没有匹配当前筛选的 PR。",
        loading: "正在载入时间线…",
      };
---

<ReportLayout
  title={copy.title}
  description={copy.description}
  nav={nav}
  activeHref={base}
  locale={locale}
>
  <article class="report">
    <header class="masthead">
      <p class="masthead__eyebrow">History track · PR-first · Draft</p>
      <h1>{copy.h1}</h1>
      <p class="masthead__sub">{copy.sub}</p>
      {
        meta && (
          <div class="masthead__meta">
            <span>Archive pin · {meta.source.sourceShort}</span>
            <span>extracted · {meta.extractedAt.slice(0, 10)}</span>
            <span>
              {meta.counts.prs} PRs · {meta.counts.commits} commits
            </span>
          </div>
        )
      }
    </header>

    <aside class="stub" aria-label="WIP">
      <p class="stub__tag">WIP · filters v1</p>
      <p>{copy.wip}</p>
    </aside>

    {
      !ready ? (
        <p class="history-empty">
          {copy.empty} <code>data/maka-history/</code> / <code>npm run history:ingest</code>
        </p>
      ) : (
        <div
          id="history-app"
          data-base={base}
          data-detail-base="/history"
          data-page-size={String(HISTORY_PAGE_SIZE)}
          data-date-locale={dateLocale}
          data-i18n={JSON.stringify({
            showing: copy.showing,
            of: copy.of,
            prs: copy.prs,
            filtered: copy.filtered,
            none: copy.none,
            prev: copy.prev,
            next: copy.next,
          })}
        >
          <script
            type="application/json"
            id="history-pr-index"
            is:inline
            set:html={JSON.stringify(prIndex)}
          />

          <form class="history-filters" id="history-filter-form" aria-label={copy.filters}>
            <label class="history-filters__field">
              <span>{copy.area}</span>
              <select name="area" id="hf-area">
                <option value="">{copy.all}</option>
                {areas.map((a) => (
                  <option value={a}>{a}</option>
                ))}
              </select>
            </label>
            <label class="history-filters__field">
              <span>{copy.author}</span>
              <input name="author" id="hf-author" list="history-authors" autocomplete="off" />
              <datalist id="history-authors">
                {authors.map((a) => (
                  <option value={a} />
                ))}
              </datalist>
            </label>
            <label class="history-filters__field">
              <span>{copy.range}</span>
              <select name="range" id="hf-range">
                <option value="all">{copy.all}</option>
                <option value="30d">{copy.d30}</option>
                <option value="90d">{copy.d90}</option>
                <option value="year">{copy.year}</option>
              </select>
            </label>
            <label class="history-filters__field history-filters__field--grow">
              <span>{copy.search}</span>
              <input name="q" id="hf-q" type="search" placeholder="title / #n" />
            </label>
            <div class="history-filters__actions">
              <button type="submit">{copy.apply}</button>
              <a class="history-filters__reset" href={base} id="hf-reset">
                {copy.reset}
              </a>
            </div>
          </form>

          <p class="history-count" id="history-count">{copy.loading}</p>
          <div id="history-list-root"></div>
          <nav class="history-pager" id="history-pager" aria-label={copy.pager}></nav>
        </div>
      )
    }
  </article>
</ReportLayout>

<script>
  type PrRow = { n: number; t: string; a: string; m: string; areas: string[] };

  function qs(): URLSearchParams {
    return new URLSearchParams(window.location.search);
  }

  function rangeStart(range: string): number | null {
    const now = Date.now();
    const day = 864e5;
    if (range === "30d") return now - 30 * day;
    if (range === "90d") return now - 90 * day;
    if (range === "year") return now - 365 * day;
    return null;
  }

  function filterRows(rows: PrRow[], sp: URLSearchParams): PrRow[] {
    const area = (sp.get("area") || "").trim();
    const author = (sp.get("author") || "").trim();
    const q = (sp.get("q") || "").trim().toLowerCase();
    const start = rangeStart(sp.get("range") || "all");
    return rows.filter((pr) => {
      if (author && pr.a !== author) return false;
      if (area && !pr.areas.includes(area)) return false;
      if (start != null) {
        const t = Date.parse(pr.m);
        if (!Number.isFinite(t) || t < start) return false;
      }
      if (q && !`${pr.t} #${pr.n} ${pr.a}`.toLowerCase().includes(q)) return false;
      return true;
    });
  }

  function fmtDate(iso: string, locale: string): string {
    try {
      return new Intl.DateTimeFormat(locale, {
        year: "numeric",
        month: "short",
        day: "numeric",
      }).format(new Date(iso));
    } catch {
      return iso.slice(0, 10);
    }
  }

  function render() {
    const app = document.getElementById("history-app");
    const raw = document.getElementById("history-pr-index");
    if (!app || !raw) return;

    const base = app.dataset.base || "/history";
    const detailBase = app.dataset.detailBase || "/history";
    const pageSize = Number(app.dataset.pageSize || "50");
    const dateLocale = app.dataset.dateLocale || "zh-CN";
    const i18n = JSON.parse(app.dataset.i18n || "{}") as Record<string, string>;
    const rows = JSON.parse(raw.textContent || "[]") as PrRow[];
    const sp = qs();

    const areaEl = document.getElementById("hf-area") as HTMLSelectElement | null;
    const authorEl = document.getElementById("hf-author") as HTMLInputElement | null;
    const rangeEl = document.getElementById("hf-range") as HTMLSelectElement | null;
    const qEl = document.getElementById("hf-q") as HTMLInputElement | null;
    if (areaEl) areaEl.value = sp.get("area") || "";
    if (authorEl) authorEl.value = sp.get("author") || "";
    if (rangeEl) rangeEl.value = sp.get("range") || "all";
    if (qEl) qEl.value = sp.get("q") || "";

    const filtered = filterRows(rows, sp);
    const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
    let page = Number(sp.get("page") || "1");
    if (!Number.isFinite(page) || page < 1) page = 1;
    page = Math.min(page, totalPages);
    const start = (page - 1) * pageSize;
    const slice = filtered.slice(start, start + pageSize);
    const active =
      Boolean(sp.get("area")) ||
      Boolean(sp.get("author")) ||
      Boolean(sp.get("q")) ||
      (sp.get("range") && sp.get("range") !== "all");

    const count = document.getElementById("history-count");
    if (count) {
      count.innerHTML = `${i18n.showing || ""} <strong>${filtered.length}</strong> ${i18n.of || ""} ${rows.length} ${i18n.prs || ""}${active ? ` ${i18n.filtered || ""}` : ""}`;
    }

    const root = document.getElementById("history-list-root");
    if (root) {
      if (slice.length === 0) {
        root.innerHTML = `<p class="history-empty">${i18n.none || ""}</p>`;
      } else {
        root.innerHTML = `<ol class="history-list" start="${start + 1}">${slice
          .map((pr) => {
            const chips = pr.areas
              .slice(0, 3)
              .map((c) => `<span class="chip">${escapeHtml(c)}</span>`)
              .join("");
            return `<li class="history-row">
              <a class="history-row__link" href="${detailBase}/pr/${pr.n}">
                <span class="history-row__num">#${pr.n}</span>
                <span class="history-row__title">${escapeHtml(pr.t)}</span>
              </a>
              <div class="history-row__meta">
                <span>${escapeHtml(pr.a)}</span>
                <span>${fmtDate(pr.m, dateLocale)}</span>
                ${chips ? `<span class="history-row__chips">${chips}</span>` : ""}
              </div>
            </li>`;
          })
          .join("")}</ol>`;
      }
    }

    const pager = document.getElementById("history-pager");
    if (pager) {
      const hrefFor = (p: number) => {
        const next = new URLSearchParams(sp);
        if (p <= 1) next.delete("page");
        else next.set("page", String(p));
        const s = next.toString();
        return s ? `${base}?${s}` : base;
      };
      const prev =
        page > 1
          ? `<a href="${hrefFor(page - 1)}">${i18n.prev || ""}</a>`
          : `<span class="history-pager__disabled">${i18n.prev || ""}</span>`;
      const next =
        page < totalPages
          ? `<a href="${hrefFor(page + 1)}">${i18n.next || ""}</a>`
          : `<span class="history-pager__disabled">${i18n.next || ""}</span>`;
      pager.innerHTML = `${prev}<span class="history-pager__status">${page} / ${totalPages}</span>${next}`;
    }
  }

  function escapeHtml(s: string): string {
    return s
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
  }

  function bind() {
    const form = document.getElementById("history-filter-form") as HTMLFormElement | null;
    const app = document.getElementById("history-app");
    if (!form || !app) return;
    const base = app.dataset.base || "/history";

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const next = new URLSearchParams();
      for (const key of ["area", "author", "range", "q"]) {
        const v = String(fd.get(key) || "").trim();
        if (!v || (key === "range" && v === "all")) continue;
        next.set(key, v);
      }
      const url = next.toString() ? `${base}?${next}` : base;
      history.pushState({}, "", url);
      render();
    });

    document.getElementById("history-pager")?.addEventListener("click", (e) => {
      const a = (e.target as HTMLElement).closest("a");
      if (!a || !a.getAttribute("href")?.startsWith(base)) return;
      e.preventDefault();
      history.pushState({}, "", a.href);
      render();
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    window.addEventListener("popstate", render);
    render();
  }

  bind();
</script>

<style>
  .history-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    align-items: end;
    margin: 1.5rem 0 0;
    padding: 1rem 0;
    border-top: 1px solid var(--hair);
    border-bottom: 1px solid var(--hair);
  }

  .history-filters__field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 9rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--mute);
  }

  .history-filters__field--grow {
    flex: 1 1 12rem;
  }

  .history-filters__field select,
  .history-filters__field input {
    font-family: var(--sans);
    font-size: 0.9rem;
    text-transform: none;
    letter-spacing: normal;
    color: var(--ink);
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--hair);
    background: var(--bg);
    border-radius: 0;
    min-width: 0;
  }

  .history-filters__actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .history-filters__actions button {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: var(--bg);
    cursor: pointer;
  }

  .history-filters__reset {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-decoration: none;
  }

  .history-count {
    margin: 1.25rem 0 0;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--mute);
  }

  .history-empty {
    margin-top: 1.75rem;
    font-family: var(--serif);
  }

  :global(.history-list) {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  :global(.history-row) {
    padding: 0.95rem 0;
    border-bottom: 1px solid var(--hair);
  }

  :global(.history-row:first-child) {
    border-top: 1px solid var(--hair);
  }

  :global(.history-row__link) {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    text-decoration: none;
    color: inherit;
  }

  :global(.history-row__link:hover .history-row__title) {
    color: var(--accent);
  }

  :global(.history-row__num) {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
    flex: 0 0 auto;
  }

  :global(.history-row__title) {
    font-family: var(--serif);
    font-size: 1.05rem;
    line-height: 1.4;
  }

  :global(.history-row__meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin-top: 0.35rem;
    padding-left: calc(0.78rem * 0.6 + 0.75rem + 2ch);
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--mute);
  }

  :global(.history-row__chips) {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  :global(.chip) {
    padding: 0.05rem 0.35rem;
    border: 1px solid var(--hair);
    background: var(--softer);
    color: var(--mute);
  }

  .history-pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2rem;
    font-family: var(--mono);
    font-size: 0.75rem;
  }

  .history-pager :global(a) {
    text-decoration: none;
  }

  :global(.history-pager__status) {
    color: var(--mute);
  }

  :global(.history-pager__disabled) {
    color: color-mix(in srgb, var(--mute) 45%, var(--bg));
  }
</style>
