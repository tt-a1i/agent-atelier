---
import ReportLayout from "../layouts/ReportLayout.astro";
import { chapterNavItems } from "../lib/chapters";
import { localePath, type Locale } from "../lib/i18n";
import {
  HISTORY_PAGE_SIZE,
  buildHistoryCommitIndex,
  buildHistoryPrIndex,
  hasMakaHistorySnapshot,
  listCommitAreas,
  listCommitAuthors,
  listPrAreas,
  listPrAuthors,
  loadCommits,
  loadMeta,
  loadPrs,
} from "../lib/maka-history";

interface Props {
  locale?: Locale;
}

const { locale = "zh" } = Astro.props;
const nav = chapterNavItems(locale);
const base = localePath(locale, "history");

const ready = hasMakaHistorySnapshot();
const meta = ready ? loadMeta() : null;
const allPrs = ready ? loadPrs() : [];
const allCommits = ready ? loadCommits() : [];
const authorsPr = ready ? listPrAuthors(allPrs) : [];
const areasPr = ready ? listPrAreas(allPrs) : [];
const authorsCommit = ready ? listCommitAuthors(allCommits) : [];
const areasCommit = ready ? listCommitAreas(allCommits) : [];
const commitIndex = ready ? buildHistoryCommitIndex() : { commits: [], firstParent: [] };
const prIndex = ready ? buildHistoryPrIndex() : [];

const dateLocale = locale === "en" ? "en-US" : "zh-CN";

const copy =
  locale === "en"
    ? {
        title: "History · Maka lineage · Agent Atelier",
        description: "Merged PR timeline for maka-agent (pinned snapshot, PR-first).",
        h1: "Maka lineage",
        sub: "Browse development by merged PR; expand a row for nested member commits. Unlinked commits sit in a trailing bucket (PR-first) and carry an unlinked mark in first-parent / full DAG.",
        wip: "Modes: PR-first (default), first-parent, full DAG. Filters run client-side against the pin. Nested member commits and the unlinked-commit bucket are live.",
        empty: "No data/maka-history/ snapshot found. Run npm run history:ingest first.",
        prev: "← Prev",
        next: "Next →",
        pager: "Pagination",
        orphanPager: "Unlinked commits pagination",
        filters: "Filters",
        mode: "Mode",
        modePr: "PR-first",
        modeFp: "First-parent",
        modeDag: "Full DAG",
        area: "Area",
        author: "Author",
        range: "Time",
        search: "Search",
        apply: "Apply",
        reset: "Reset",
        all: "All",
        d30: "30 days",
        d90: "90 days",
        year: "1 year",
        showing: "Showing",
        of: "of",
        prs: "PRs",
        commits: "commits",
        filtered: "(filtered)",
        none: "No rows match these filters.",
        loading: "Loading timeline…",
        merge: "merge",
        parents: "parents",
        members: "member commits",
        unlinked: "unlinked",
        orphanTitle: "Unlinked commits",
        orphanLede: "Commits in the pin with no merged PR association — collapsed by default, never dropped.",
        orphanEmpty: "No unlinked commits match these filters.",
        orphanShowing: "Unlinked",
      }
    : {
        title: "History · Maka 演进轨 · Agent Atelier",
        description: "Maka 仓库合并 PR 时间线（pinned snapshot，PR-first）。",
        h1: "Maka 演进史",
        sub: "默认按已合并 PR 浏览；展开行可见嵌套成员 commit。无 PR 关联的提交落在末尾「未关联提交」桶（PR-first），并在 first-parent / full DAG 中带 unlinked 标记。",
        wip: "模式：PR-first（默认）/ first-parent / full DAG。筛选在客户端对 pin 运行。列表内嵌套成员 commit 与未关联提交桶已上线。",
        empty: "尚未找到 data/maka-history/ 快照。请先运行 npm run history:ingest。",
        prev: "← 上一页",
        next: "下一页 →",
        pager: "分页",
        orphanPager: "未关联提交分页",
        filters: "筛选",
        mode: "模式",
        modePr: "PR-first",
        modeFp: "First-parent",
        modeDag: "Full DAG",
        area: "区域",
        author: "作者",
        range: "时间",
        search: "搜索",
        apply: "应用",
        reset: "重置",
        all: "全部",
        d30: "30 天",
        d90: "90 天",
        year: "一年",
        showing: "显示",
        of: "/",
        prs: "条 PR",
        commits: "条 commit",
        filtered: "（已筛选）",
        none: "没有匹配当前筛选的条目。",
        loading: "正在载入时间线…",
        merge: "merge",
        parents: "parents",
        members: "条成员 commit",
        unlinked: "unlinked",
        orphanTitle: "未关联提交",
        orphanLede: "快照中无已合并 PR 关联的 commit — 默认折叠，不会静默丢弃。",
        orphanEmpty: "没有匹配当前筛选的未关联提交。",
        orphanShowing: "未关联",
      };
---

<ReportLayout
  title={copy.title}
  description={copy.description}
  nav={nav}
  activeHref={base}
  locale={locale}
>
  <article class="report">
    <header class="masthead">
      <p class="masthead__eyebrow">History track · PR-first</p>
      <h1>{copy.h1}</h1>
      <p class="masthead__sub">{copy.sub}</p>
      {
        meta && (
          <div class="masthead__meta">
            <span>Archive pin · {meta.source.sourceShort}</span>
            <span>extracted · {meta.extractedAt.slice(0, 10)}</span>
            <span>
              {meta.counts.prs} PRs · {meta.counts.commits} commits
            </span>
          </div>
        )
      }
    </header>

    <aside class="history-note" aria-label={locale === "en" ? "History track note" : "演进轨说明"}>
      <p class="history-note__tag">{locale === "en" ? "Note" : "说明"}</p>
      <p>{copy.wip}</p>
    </aside>

    {
      !ready ? (
        <p class="history-empty">
          {copy.empty} <code>data/maka-history/</code> / <code>npm run history:ingest</code>
        </p>
      ) : (
        <div
          id="history-app"
          data-base={base}
          data-detail-base={base}
          data-page-size={String(HISTORY_PAGE_SIZE)}
          data-date-locale={dateLocale}
          data-i18n={JSON.stringify({
            showing: copy.showing,
            of: copy.of,
            prs: copy.prs,
            commits: copy.commits,
            filtered: copy.filtered,
            none: copy.none,
            prev: copy.prev,
            next: copy.next,
            merge: copy.merge,
            parents: copy.parents,
            members: copy.members,
            unlinked: copy.unlinked,
            orphanTitle: copy.orphanTitle,
            orphanLede: copy.orphanLede,
            orphanEmpty: copy.orphanEmpty,
            orphanShowing: copy.orphanShowing,
            orphanPager: copy.orphanPager,
          })}
        >
          <script
            type="application/json"
            id="history-pr-index"
            is:inline
            set:html={JSON.stringify(prIndex)}
          />
          <script
            type="application/json"
            id="history-commit-index"
            is:inline
            set:html={JSON.stringify(commitIndex)}
          />
          <script
            type="application/json"
            id="history-filter-options"
            is:inline
            set:html={JSON.stringify({
              pr: { authors: authorsPr, areas: areasPr },
              commit: { authors: authorsCommit, areas: areasCommit },
            })}
          />

          <form class="history-filters" id="history-filter-form" aria-label={copy.filters}>
            <fieldset class="history-modes">
              <legend>{copy.mode}</legend>
              <label>
                <input type="radio" name="mode" value="pr" id="hf-mode-pr" checked />
                {copy.modePr}
              </label>
              <label>
                <input type="radio" name="mode" value="fp" id="hf-mode-fp" />
                {copy.modeFp}
              </label>
              <label>
                <input type="radio" name="mode" value="dag" id="hf-mode-dag" />
                {copy.modeDag}
              </label>
            </fieldset>
            <label class="history-filters__field">
              <span>{copy.area}</span>
              <select name="area" id="hf-area">
                <option value="">{copy.all}</option>
              </select>
            </label>
            <label class="history-filters__field">
              <span>{copy.author}</span>
              <input name="author" id="hf-author" list="history-authors" autocomplete="off" />
              <datalist id="history-authors"></datalist>
            </label>
            <label class="history-filters__field">
              <span>{copy.range}</span>
              <select name="range" id="hf-range">
                <option value="all">{copy.all}</option>
                <option value="30d">{copy.d30}</option>
                <option value="90d">{copy.d90}</option>
                <option value="year">{copy.year}</option>
              </select>
            </label>
            <label class="history-filters__field history-filters__field--grow">
              <span>{copy.search}</span>
              <input name="q" id="hf-q" type="search" placeholder="title / subject / #n" />
            </label>
            <div class="history-filters__actions">
              <button type="submit">{copy.apply}</button>
              <a class="history-filters__reset" href={base} id="hf-reset">
                {copy.reset}
              </a>
            </div>
          </form>

          <p class="history-count" id="history-count">{copy.loading}</p>
          <div id="history-list-root"></div>
          <nav class="history-pager" id="history-pager" aria-label={copy.pager}></nav>
          <div id="history-orphan-root"></div>
        </div>
      )
    }
  </article>
</ReportLayout>

<script>
  type PrRow = {
    n: number;
    t: string;
    a: string;
    m: string;
    areas: string[];
    cs: { s: string; sub: string }[];
  };
  type CommitRow = {
    s: string;
    sub: string;
    a: string;
    d: string;
    areas: string[];
    m: boolean;
    p: string[];
    o: boolean;
  };
  type Mode = "pr" | "fp" | "dag";

  function qs(): URLSearchParams {
    return new URLSearchParams(window.location.search);
  }

  function parseMode(raw: string | null): Mode {
    if (raw === "fp" || raw === "first-parent") return "fp";
    if (raw === "dag" || raw === "full") return "dag";
    return "pr";
  }

  function rangeStart(range: string): number | null {
    const now = Date.now();
    const day = 864e5;
    if (range === "30d") return now - 30 * day;
    if (range === "90d") return now - 90 * day;
    if (range === "year") return now - 365 * day;
    return null;
  }

  function filterPrs(rows: PrRow[], sp: URLSearchParams): PrRow[] {
    const area = (sp.get("area") || "").trim();
    const author = (sp.get("author") || "").trim();
    const q = (sp.get("q") || "").trim().toLowerCase();
    const start = rangeStart(sp.get("range") || "all");
    return rows.filter((pr) => {
      if (author && pr.a !== author) return false;
      if (area && !pr.areas.includes(area)) return false;
      if (start != null) {
        const t = Date.parse(pr.m);
        if (!Number.isFinite(t) || t < start) return false;
      }
      if (q) {
        const memberHay = pr.cs.map((c) => `${c.s} ${c.sub}`).join(" ");
        if (!`${pr.t} #${pr.n} ${pr.a} ${memberHay}`.toLowerCase().includes(q)) return false;
      }
      return true;
    });
  }

  function filterCommits(rows: CommitRow[], sp: URLSearchParams): CommitRow[] {
    const area = (sp.get("area") || "").trim();
    const author = (sp.get("author") || "").trim();
    const q = (sp.get("q") || "").trim().toLowerCase();
    const start = rangeStart(sp.get("range") || "all");
    return rows.filter((c) => {
      if (author && c.a !== author) return false;
      if (area && !c.areas.includes(area)) return false;
      if (start != null) {
        const t = Date.parse(c.d);
        if (!Number.isFinite(t) || t < start) return false;
      }
      if (q && !`${c.sub} ${c.s} ${c.a}`.toLowerCase().includes(q)) return false;
      return true;
    });
  }

  function fmtDate(iso: string, locale: string): string {
    try {
      return new Intl.DateTimeFormat(locale, {
        year: "numeric",
        month: "short",
        day: "numeric",
      }).format(new Date(iso));
    } catch {
      return iso.slice(0, 10);
    }
  }

  function escapeHtml(s: string): string {
    return s
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
  }

  function fillFilterOptions(mode: Mode) {
    const raw = document.getElementById("history-filter-options");
    if (!raw) return;
    const opts = JSON.parse(raw.textContent || "{}") as {
      pr: { authors: string[]; areas: string[] };
      commit: { authors: string[]; areas: string[] };
    };
    const pack = mode === "pr" ? opts.pr : opts.commit;
    const areaEl = document.getElementById("hf-area") as HTMLSelectElement | null;
    const list = document.getElementById("history-authors");
    if (areaEl) {
      const current = areaEl.value;
      const allLabel = areaEl.options[0]?.textContent || "";
      areaEl.innerHTML = `<option value="">${escapeHtml(allLabel)}</option>${pack.areas
        .map((a) => `<option value="${escapeHtml(a)}">${escapeHtml(a)}</option>`)
        .join("")}`;
      if (pack.areas.includes(current)) areaEl.value = current;
    }
    if (list) {
      list.innerHTML = pack.authors
        .map((a) => `<option value="${escapeHtml(a)}"></option>`)
        .join("");
    }
  }

  function commitRowHtml(
    c: CommitRow,
    detailBase: string,
    dateLocale: string,
    i18n: Record<string, string>,
    mode: Mode,
  ): string {
    const chips = c.areas
      .slice(0, 3)
      .map((x) => `<span class="chip">${escapeHtml(x)}</span>`)
      .join("");
    const merge = c.m
      ? `<span class="chip chip--merge">${i18n.merge || "merge"}</span>`
      : "";
    const unlinked = c.o
      ? `<span class="chip chip--orphan">${i18n.unlinked || "unlinked"}</span>`
      : "";
    const parents =
      mode === "dag" && c.p.length
        ? `<span>${i18n.parents || "parents"} ${c.p
            .map((p) => escapeHtml(p))
            .join(" · ")}</span>`
        : "";
    return `<li class="history-row">
      <a class="history-row__link" href="${detailBase}/c/${escapeHtml(c.s)}">
        <span class="history-row__num">${escapeHtml(c.s)}</span>
        <span class="history-row__title">${escapeHtml(c.sub)}</span>
      </a>
      <div class="history-row__meta">
        <span>${escapeHtml(c.a)}</span>
        <span>${fmtDate(c.d, dateLocale)}</span>
        ${merge}
        ${unlinked}
        ${parents}
        ${chips ? `<span class="history-row__chips">${chips}</span>` : ""}
      </div>
    </li>`;
  }

  function paintPager(
    el: HTMLElement | null,
    sp: URLSearchParams,
    base: string,
    page: number,
    totalPages: number,
    i18n: Record<string, string>,
    pageKey = "page",
  ) {
    if (!el) return;
    const hrefFor = (p: number) => {
      const next = new URLSearchParams(sp);
      if (p <= 1) next.delete(pageKey);
      else next.set(pageKey, String(p));
      const s = next.toString();
      return s ? `${base}?${s}` : base;
    };
    const prev =
      page > 1
        ? `<a href="${hrefFor(page - 1)}">${i18n.prev || ""}</a>`
        : `<span class="history-pager__disabled">${i18n.prev || ""}</span>`;
    const next =
      page < totalPages
        ? `<a href="${hrefFor(page + 1)}">${i18n.next || ""}</a>`
        : `<span class="history-pager__disabled">${i18n.next || ""}</span>`;
    el.innerHTML = `${prev}<span class="history-pager__status">${page} / ${totalPages}</span>${next}`;
  }

  function renderOrphanBucket(
    orphans: CommitRow[],
    sp: URLSearchParams,
    base: string,
    detailBase: string,
    pageSize: number,
    dateLocale: string,
    i18n: Record<string, string>,
  ) {
    const root = document.getElementById("history-orphan-root");
    if (!root) return;

    const totalPages = Math.max(1, Math.ceil(orphans.length / pageSize) || 1);
    let page = Number(sp.get("opage") || "1");
    if (!Number.isFinite(page) || page < 1) page = 1;
    page = Math.min(page, totalPages);
    const start = (page - 1) * pageSize;
    const slice = orphans.slice(start, start + pageSize);
    const open = sp.get("orphan") === "1" || Boolean(sp.get("opage"));

    const list =
      orphans.length === 0
        ? `<p class="history-empty history-orphan__empty">${i18n.orphanEmpty || ""}</p>`
        : `<ol class="history-list history-orphan__list" start="${start + 1}">${slice
            .map((c) => commitRowHtml(c, detailBase, dateLocale, i18n, "pr"))
            .join("")}</ol>
          <nav class="history-pager history-orphan__pager" id="history-orphan-pager" aria-label="${escapeHtml(i18n.orphanPager || "")}"></nav>`;

    root.innerHTML = `<details class="history-orphan" ${open ? "open" : ""}>
      <summary class="history-orphan__summary">
        <span class="history-orphan__title">${escapeHtml(i18n.orphanTitle || "")}</span>
        <span class="history-orphan__count">${orphans.length}</span>
      </summary>
      <p class="history-orphan__lede">${escapeHtml(i18n.orphanLede || "")}</p>
      <p class="history-count">${i18n.orphanShowing || ""} <strong>${orphans.length}</strong></p>
      ${list}
    </details>`;

    const pager = document.getElementById("history-orphan-pager");
    if (orphans.length > 0) {
      paintPager(pager, sp, base, page, totalPages, i18n, "opage");
    }
  }

  function render() {
    const app = document.getElementById("history-app");
    const prRaw = document.getElementById("history-pr-index");
    const cRaw = document.getElementById("history-commit-index");
    if (!app || !prRaw || !cRaw) return;

    const base = app.dataset.base || "/history";
    const detailBase = app.dataset.detailBase || base;
    const pageSize = Number(app.dataset.pageSize || "50");
    const dateLocale = app.dataset.dateLocale || "zh-CN";
    const i18n = JSON.parse(app.dataset.i18n || "{}") as Record<string, string>;
    const prs = JSON.parse(prRaw.textContent || "[]") as PrRow[];
    const commitPack = JSON.parse(cRaw.textContent || "{}") as {
      commits: CommitRow[];
      firstParent: string[];
    };
    const byShort = new Map(commitPack.commits.map((c) => [c.s, c]));
    const sp = qs();
    const mode = parseMode(sp.get("mode"));

    fillFilterOptions(mode);

    const modePr = document.getElementById("hf-mode-pr") as HTMLInputElement | null;
    const modeFp = document.getElementById("hf-mode-fp") as HTMLInputElement | null;
    const modeDag = document.getElementById("hf-mode-dag") as HTMLInputElement | null;
    if (modePr) modePr.checked = mode === "pr";
    if (modeFp) modeFp.checked = mode === "fp";
    if (modeDag) modeDag.checked = mode === "dag";

    const areaEl = document.getElementById("hf-area") as HTMLSelectElement | null;
    const authorEl = document.getElementById("hf-author") as HTMLInputElement | null;
    const rangeEl = document.getElementById("hf-range") as HTMLSelectElement | null;
    const qEl = document.getElementById("hf-q") as HTMLInputElement | null;
    if (areaEl) areaEl.value = sp.get("area") || "";
    if (authorEl) authorEl.value = sp.get("author") || "";
    if (rangeEl) rangeEl.value = sp.get("range") || "all";
    if (qEl) qEl.value = sp.get("q") || "";

    let unit = i18n.prs || "";
    let totalBase = 0;
    let filteredLen = 0;
    let listHtml = "";
    const orphanRoot = document.getElementById("history-orphan-root");

    if (mode === "pr") {
      const filtered = filterPrs(prs, sp);
      totalBase = prs.length;
      filteredLen = filtered.length;
      unit = i18n.prs || "";
      const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
      let page = Number(sp.get("page") || "1");
      if (!Number.isFinite(page) || page < 1) page = 1;
      page = Math.min(page, totalPages);
      const start = (page - 1) * pageSize;
      const slice = filtered.slice(start, start + pageSize);
      listHtml =
        slice.length === 0
          ? `<p class="history-empty">${i18n.none || ""}</p>`
          : `<ol class="history-list" start="${start + 1}">${slice
              .map((pr) => {
                const chips = pr.areas
                  .slice(0, 3)
                  .map((c) => `<span class="chip">${escapeHtml(c)}</span>`)
                  .join("");
                const nest =
                  pr.cs.length > 0
                    ? `<details class="history-nest">
                        <summary class="history-nest__summary">${pr.cs.length} ${i18n.members || ""}</summary>
                        <ul class="history-nest__list">
                          ${pr.cs
                            .map(
                              (c) => `<li>
                            <a href="${detailBase}/c/${escapeHtml(c.s)}">
                              <code>${escapeHtml(c.s)}</code>
                              <span>${escapeHtml(c.sub)}</span>
                            </a>
                          </li>`,
                            )
                            .join("")}
                        </ul>
                      </details>`
                    : "";
                return `<li class="history-row">
              <a class="history-row__link" href="${detailBase}/pr/${pr.n}">
                <span class="history-row__num">#${pr.n}</span>
                <span class="history-row__title">${escapeHtml(pr.t)}</span>
              </a>
              <div class="history-row__meta">
                <span>${escapeHtml(pr.a)}</span>
                <span>${fmtDate(pr.m, dateLocale)}</span>
                ${chips ? `<span class="history-row__chips">${chips}</span>` : ""}
              </div>
              ${nest}
            </li>`;
              })
              .join("")}</ol>`;
      paintPager(document.getElementById("history-pager"), sp, base, page, totalPages, i18n);

      const orphans = filterCommits(
        commitPack.commits.filter((c) => c.o),
        sp,
      ).sort((a, b) => Date.parse(b.d) - Date.parse(a.d));
      renderOrphanBucket(orphans, sp, base, detailBase, pageSize, dateLocale, i18n);
    } else {
      if (orphanRoot) orphanRoot.innerHTML = "";
      const ordered: CommitRow[] =
        mode === "fp"
          ? (commitPack.firstParent.map((s) => byShort.get(s)).filter(Boolean) as CommitRow[])
          : [...commitPack.commits].sort((a, b) => Date.parse(b.d) - Date.parse(a.d));
      const filtered = filterCommits(ordered, sp);
      totalBase = ordered.length;
      filteredLen = filtered.length;
      unit = i18n.commits || "";
      const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
      let page = Number(sp.get("page") || "1");
      if (!Number.isFinite(page) || page < 1) page = 1;
      page = Math.min(page, totalPages);
      const start = (page - 1) * pageSize;
      const slice = filtered.slice(start, start + pageSize);
      listHtml =
        slice.length === 0
          ? `<p class="history-empty">${i18n.none || ""}</p>`
          : `<ol class="history-list" start="${start + 1}">${slice
              .map((c) => commitRowHtml(c, detailBase, dateLocale, i18n, mode))
              .join("")}</ol>`;
      paintPager(document.getElementById("history-pager"), sp, base, page, totalPages, i18n);
    }

    const active =
      Boolean(sp.get("area")) ||
      Boolean(sp.get("author")) ||
      Boolean(sp.get("q")) ||
      (sp.get("range") && sp.get("range") !== "all");

    const count = document.getElementById("history-count");
    if (count) {
      count.innerHTML = `${i18n.showing || ""} <strong>${filteredLen}</strong> ${i18n.of || ""} ${totalBase} ${unit}${active ? ` ${i18n.filtered || ""}` : ""}`;
    }

    const root = document.getElementById("history-list-root");
    if (root) root.innerHTML = listHtml;
  }

  function collectParams(form: HTMLFormElement): URLSearchParams {
    const fd = new FormData(form);
    const next = new URLSearchParams();
    const mode = String(fd.get("mode") || "pr");
    if (mode && mode !== "pr") next.set("mode", mode);
    for (const key of ["area", "author", "range", "q"]) {
      const v = String(fd.get(key) || "").trim();
      if (!v || (key === "range" && v === "all")) continue;
      next.set(key, v);
    }
    return next;
  }

  function bind() {
    const form = document.getElementById("history-filter-form") as HTMLFormElement | null;
    const app = document.getElementById("history-app");
    if (!form || !app) return;
    const base = app.dataset.base || "/history";

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const next = collectParams(form);
      const url = next.toString() ? `${base}?${next}` : base;
      history.pushState({}, "", url);
      render();
    });

    form.querySelectorAll('input[name="mode"]').forEach((el) => {
      el.addEventListener("change", () => {
        const next = collectParams(form);
        next.delete("page");
        next.delete("opage");
        next.delete("orphan");
        const url = next.toString() ? `${base}?${next}` : base;
        history.pushState({}, "", url);
        render();
      });
    });

    const onPagerClick = (e: Event) => {
      const a = (e.target as HTMLElement).closest("a");
      if (!a || !a.getAttribute("href")?.startsWith(base)) return;
      e.preventDefault();
      history.pushState({}, "", a.href);
      render();
      window.scrollTo({ top: 0, behavior: "smooth" });
    };
    document.getElementById("history-pager")?.addEventListener("click", onPagerClick);
    document.getElementById("history-orphan-root")?.addEventListener("click", (e) => {
      const a = (e.target as HTMLElement).closest("a");
      if (a && a.getAttribute("href")?.startsWith(base) && a.closest(".history-pager")) {
        e.preventDefault();
        const url = new URL(a.href, window.location.origin);
        url.searchParams.set("orphan", "1");
        history.pushState({}, "", `${url.pathname}${url.search}`);
        render();
        return;
      }
    });
    document.getElementById("history-orphan-root")?.addEventListener("toggle", (e) => {
      const details = e.target as HTMLDetailsElement;
      if (!(details instanceof HTMLDetailsElement) || !details.classList.contains("history-orphan")) {
        return;
      }
      const next = qs();
      if (details.open) next.set("orphan", "1");
      else {
        next.delete("orphan");
        next.delete("opage");
      }
      const url = next.toString() ? `${base}?${next}` : base;
      history.replaceState({}, "", url);
    }, true);

    window.addEventListener("popstate", render);
    render();
  }

  bind();
</script>

