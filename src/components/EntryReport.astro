---
import ReportLayout from "../layouts/ReportLayout.astro";
import Section from "./Section.astro";
import DiagramFigure from "./diagrams/DiagramFigure.astro";
import EntryDualTrackFlow from "./diagrams/EntryDualTrackFlow.astro";
import {
  ARCHITECTURE_SENTENCE,
  CHAPTERS,
  LAYERS,
  chapterHref,
  chapterNavItems,
  type ChapterId,
} from "../lib/chapters";
import { LAYER_LABELS, chrome, localePath, type Locale } from "../lib/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "zh" } = Astro.props;
const nav = chapterNavItems(locale);
const layers = LAYERS[locale];
const layerLabels = LAYER_LABELS[locale];
const t = chrome(locale);
const historyHref = localePath(locale, "history");
const allChaptersDone = CHAPTERS.every((c) => c.status === "done");

function chapterLinks(ids: ChapterId[]) {
  return ids.map((id) => CHAPTERS.find((c) => c.id === id)!);
}

const copy =
  locale === "en"
    ? {
        title: "Dissecting Agents with Maka · Agent Atelier",
        description:
          "Maka is a log-first, projection-driven Agent Runtime. Follow six milestone chapters to learn a complete Agent structure.",
        eyebrow: "Agent Learning Report · Specimen: Maka",
        h1: "Dissecting Agents with Maka",
        metaCog: "Cognitive track · §01–§06",
        metaSpecimen: "Specimen · maka-agent",
        metaGenre: "Form · research report",
        metaHistory: "History track",
        layersLabel: "Mental model",
        layersTitle: "A three-layer mental model",
        layersLede:
          "The same execution facts are projected for different consumers — learn the layers, then enter chapters.",
        layerChapters: "Chapters:",
        tocLabel: "Six chapters",
        tocTitle: "Chapter index",
        tocLede:
          "Routes match Maka ARCHITECTURE English titles 1:1. Done = structure hard gate (necessary, not sufficient). Mechanism depth is a separate pass — in progress.",
        tracksLabel: "Dual track",
        tracksTitle: "Cognitive track and history track",
        tracksLede:
          "Milestones teach structure and protocols; full commit/PR lineage lives at /history.",
        tracksBody:
          "The cognitive track advances through six milestone chapters instead of dumping every commit into the TOC. To ask when a mechanism matured, open /history (PR-first snapshot) or follow sparse in-chapter evolution asides. Depth mining now covers the whole maka-agent corpus (docs + design-bearing code), not only the six ARCHITECTURE essays.",
        pull: "This site is for readers who want to understand how an Agent keeps its ledger, thins context, reviews failure, and improves in a falsifiable way — not only how to call an API.",
        pathsLabel: "Reading paths",
        pathsTitle: "Choose a path by problem",
        pathsLede: "Same six chapters; different entry orders.",
        dualCaption:
          "Fig. · Dual track: §01–§06 teach structure; /history holds the PR-first lineage with sparse asides bridging back.",
        dualAlt:
          "Two columns: Cognitive track §01–§06 milestones versus History track /history archive with PR-first filters and cross-links.",
        wipNote: allChaptersDone
          ? "Structure hard gate green for §01–§06. Depth pass in progress — Destination NOT complete. Corpus dig status: docs/research/depth-corpus-status.md · map #34."
          : "Acceptance checklist is a hard gate. TOC WIP means unfinished — not a completed curriculum.",
        depthNote:
          "Cluster 1 named fat seams are deep or outline+shipped (incl. storage ledgers, usage/capture, runtime-host four-op gateway this pass). Archive mine-delta largely absorbed (top-3 + batch-2). Destination bar still open under #34 — companions may need hostile-reader pass; Target stubs + entry honesty remain.",
        paths: [
          {
            title: "First time in the Runtime",
            body: "Read §01 → §02 → §03. Facts, then tool evidence, then history projection. Inside §01, do not skip #request-shape (cache / prefixHash).",
          },
          {
            title: "Tool, context, compaction, or cost",
            body: "§01 (#request-shape) → §02 → §03. Prune/compact change provider-visible shape; cost attribution lives in §01.",
          },
          {
            title: "Headless, Self-check, or AHE",
            body: "§01 → §04 → §05 → §06. All six are in the even-depth pass — not Hybrid-lean stubs. Corpus seams beyond these essays are still being mined.",
          },
        ],
      }
    : {
        title: "用 Maka 解剖 Agent · Agent Atelier",
        description:
          "Maka 是 log-first、projection-driven 的 Agent Runtime。沿六章里程碑理解完整 Agent 结构。",
        eyebrow: "Agent Learning Report · Specimen: Maka",
        h1: "用 Maka 解剖 Agent",
        metaCog: "认知轨 · §01–§06",
        metaSpecimen: "标本 · maka-agent",
        metaGenre: "体裁 · research report",
        metaHistory: "演进轨",
        layersLabel: "心智模型",
        layersTitle: "三层心智模型",
        layersLede: "同一组运行事实，被投影给不同消费者；先分清层，再进章节。",
        layerChapters: "对应章节：",
        tocLabel: "六章",
        tocTitle: "六章索引",
        tocLede:
          "路由与 Maka ARCHITECTURE 英文章名 1:1。「完成」= 结构硬闸门（必要但不充分）。机制深度是另一条关卡——进行中。",
        tracksLabel: "双轨",
        tracksTitle: "认知轨与演进轨",
        tracksLede: "里程碑讲结构与协议；完整 commit/PR 谱系在 /history。",
        tracksBody:
          "认知轨按六章里程碑推进，不把仓库每一笔提交摊成目录。需要追「这一机制何时长成」时，进入 /history（PR-first 快照），或在章内稀疏的演进旁注中跳转。深度挖掘范围已抬到整个 maka-agent 语料（文档 + 设计代码），不止六篇 ARCHITECTURE 章。",
        pull: "目标读者不是「只会调 API 的人」，而是想弄清 Agent 内部账本怎么记、上下文怎么瘦、失败怎么复盘、系统如何可证伪地改进的人。",
        pathsLabel: "阅读路径",
        pathsTitle: "按问题选择阅读路径",
        pathsLede: "六章不变，入口顺序可变。",
        dualCaption:
          "图 · 双轨：§01–§06 讲结构；/history 承载 PR-first 谱系，章内旁注稀疏回链。",
        dualAlt:
          "两列对照：认知轨 §01–§06 里程碑，与演进轨 /history 档案（PR-first、筛选、交叉引用）。",
        wipNote: allChaptersDone
          ? "结构硬闸门已绿。深度关卡进行中——Destination 未完成。语料状态见 docs/research/depth-corpus-status.md · map #34。"
          : "验收清单是硬闸门。目录上的 WIP 表示未完成，不是已结业课程。",
        depthNote:
          "Cluster 1 具名肥缝已 deep 或 outline+shipped（本趟含 storage ledgers、usage/capture、runtime-host 四操作网关）。Archive mine-delta 大体已吸收（top-3 + batch-2）。Destination 门槛仍开放于 #34——companion 或需敌意复读；Target stub 与入口诚实文案仍在。",
        paths: [
          {
            title: "第一次进入 Runtime",
            body: "按 §01 → §02 → §03。先事实日志，再工具证据，再历史投影。§01 内不要跳过 #request-shape（cache / prefixHash）。",
          },
          {
            title: "改 Tool、上下文、Compaction 或成本",
            body: "§01（#request-shape）→ §02 → §03。prune/compact 改变 provider-visible shape；成本归因在 §01。",
          },
          {
            title: "改 Headless、Self-check 或 AHE",
            body: "§01 → §04 → §05 → §06。六章都在 even-depth 关卡内——不是 Hybrid lean stubs。章外语料缝仍在挖掘。",
          },
        ],
      };

const requestShapeHref = `${chapterHref("01-log-is-the-runtime", locale)}#request-shape`;
---

<ReportLayout
  title={copy.title}
  description={copy.description}
  nav={nav}
  activeHref={localePath(locale, "")}
  locale={locale}
>
  <article class="report">
    <header class="masthead">
      <p class="masthead__eyebrow">{copy.eyebrow}</p>
      <h1>{copy.h1}</h1>
      <p class="masthead__sub masthead__sub--architecture">
        {ARCHITECTURE_SENTENCE[locale]}
      </p>
      <div class="masthead__meta">
        <span>{copy.metaCog}</span>
        <span>{copy.metaSpecimen}</span>
        <span>{copy.metaGenre}</span>
        <span>
          {copy.metaHistory} · <a href={historyHref}>/history</a>
        </span>
      </div>
    </header>

    <Section
      id="layers"
      label={copy.layersLabel}
      title={copy.layersTitle}
      lede={copy.layersLede}
    >
      <ol class="layer-list">
        {
          layers.map((layer) => (
            <li class="layer-card">
              <p class="layer-card__n">
                {layer.n}. {layer.title}
              </p>
              <p class="layer-card__body">{layer.body}</p>
              <p class="layer-card__chapters">
                {copy.layerChapters}{" "}
                {chapterLinks(layer.chapters).map((c, i) => (
                  <span>
                    {i > 0 ? " · " : ""}
                    <a href={chapterHref(c.slug, locale)}>
                      §{c.id} {locale === "en" ? c.titleEn : c.titleZh}
                    </a>
                  </span>
                ))}
              </p>
            </li>
          ))
        }
      </ol>
    </Section>

    <Section id="chapters" label={copy.tocLabel} title={copy.tocTitle} lede={copy.tocLede}>
      <ol class="chapter-toc">
        {
          CHAPTERS.map((c) => (
            <li class="chapter-toc__item">
              <a class="chapter-toc__link" href={chapterHref(c.slug, locale)}>
                <span class="chapter-toc__id">§{c.id}</span>
                <span class="chapter-toc__titles">
                  <span class="chapter-toc__zh">
                    {locale === "en" ? c.titleEn : c.titleZh}
                  </span>
                  <span class="chapter-toc__en">
                    {locale === "en" ? c.titleZh : c.titleEn}
                  </span>
                </span>
                <span class="chapter-toc__meta">
                  <span class="chapter-toc__layer">{layerLabels[c.layer]}</span>
                  <span class:list={["chapter-toc__badge", c.status === "done" && "chapter-toc__badge--done"]}>
                    {c.status === "done" ? t.tocDone : t.tocWip}
                  </span>
                </span>
              </a>
              <p class="chapter-toc__q">
                {locale === "en" ? c.questionEn : c.questionZh}
              </p>
            </li>
          ))
        }
      </ol>
    </Section>

    <Section
      id="paths"
      label={copy.pathsLabel}
      title={copy.pathsTitle}
      lede={copy.pathsLede}
    >
      <ol class="path-list">
        {
          copy.paths.map((path, i) => (
            <li class="path-card">
              <p class="path-card__n">
                {i + 1}. {path.title}
              </p>
              <p class="path-card__body">{path.body}</p>
            </li>
          ))
        }
      </ol>
    </Section>

    <Section
      id="tracks"
      label={copy.tracksLabel}
      title={copy.tracksTitle}
      lede={copy.tracksLede}
    >
      <DiagramFigure caption={copy.dualCaption} alt={copy.dualAlt}>
        <EntryDualTrackFlow />
      </DiagramFigure>
      <p>{copy.tracksBody}</p>
      <p class="entry-wip-note">{copy.wipNote}</p>
      <p class="entry-depth-note">
        {copy.depthNote}{" "}
        <a href={requestShapeHref}>§01 · #request-shape</a>
        {" · "}
        <a href={`${chapterHref("01-log-is-the-runtime", locale)}#execution-evidence`}
          >§01 · #execution-evidence</a
        >
        {" · "}
        <a href={`${chapterHref("01-log-is-the-runtime", locale)}#trust`}>§01 · #trust</a>
        {" · "}
        <a href={localePath(locale, "guides/security-privacy")}>/guides/security-privacy</a>
        {" · "}
        <a href={`${chapterHref("02-evidence-before-compression", locale)}#shell-side-effects`}
          >§02 · #shell-side-effects</a
        >
        {" · "}
        <a href={`${chapterHref("02-evidence-before-compression", locale)}#filesystem-worker`}
          >§02 · #filesystem-worker</a
        >
        {" · "}
        <a href={localePath(locale, "guides/desktop-host")}>/guides/desktop-host</a>
        {" · "}
        <a href={localePath(locale, "guides/bot-im")}>/guides/bot-im</a>
        {" · "}
        <a href={historyHref}>/history</a>
      </p>
      <blockquote class="pull">{copy.pull}</blockquote>
    </Section>
  </article>
</ReportLayout>

<style>
  .masthead__sub--architecture {
    font-style: normal;
    font-size: 1.12rem;
    line-height: 1.65;
    color: var(--ink);
    max-width: 42em;
  }

  .layer-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
  }

  .layer-card {
    padding: 0 0 1.35rem;
    border-bottom: 1px solid var(--hair);
  }

  .layer-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .layer-card__n {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.45rem;
  }

  .layer-card__body {
    font-family: var(--serif);
    margin: 0 0 0.65rem;
    max-width: 40em;
  }

  .layer-card__chapters {
    margin: 0;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--mute);
  }

  .path-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .path-card {
    padding: 0 0 1.1rem;
    border-bottom: 1px solid var(--hair);
  }

  .path-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .path-card__n {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.4rem;
  }

  .path-card__body {
    margin: 0;
    font-family: var(--serif);
    max-width: 40em;
  }

  .chapter-toc {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .chapter-toc__item {
    padding: 1.15rem 0;
    border-bottom: 1px solid var(--hair);
  }

  .chapter-toc__item:last-child {
    border-bottom: none;
  }

  .chapter-toc__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem 1rem;
    align-items: baseline;
    text-decoration: none;
    color: inherit;
  }

  .chapter-toc__link:hover .chapter-toc__zh {
    color: var(--accent);
  }

  .chapter-toc__id {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  .chapter-toc__titles {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .chapter-toc__zh {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.2rem;
    transition: color 0.15s ease;
  }

  .chapter-toc__en {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--mute);
  }

  .chapter-toc__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--mute);
  }

  .chapter-toc__badge {
    color: var(--mute);
  }

  .chapter-toc__badge--done {
    color: var(--accent);
  }

  .chapter-toc__q {
    margin: 0.55rem 0 0 0;
    padding-left: calc(0.78rem * 3.2);
    font-family: var(--serif);
    font-size: 0.98rem;
    color: var(--mute);
    max-width: 40em;
  }

  .entry-wip-note,
  .entry-depth-note {
    margin: 1rem 0 0;
    max-width: 42em;
    font-family: var(--mono);
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--mute);
  }

  .entry-depth-note {
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .chapter-toc__link {
      grid-template-columns: auto 1fr;
    }

    .chapter-toc__meta {
      grid-column: 2;
      flex-direction: row;
      align-items: center;
      gap: 0.75rem;
    }

    .chapter-toc__q {
      padding-left: 0;
    }
  }
</style>
