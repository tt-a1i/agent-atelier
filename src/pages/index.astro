---
import ReportLayout from "../layouts/ReportLayout.astro";
import Section from "../components/Section.astro";
import {
  ARCHITECTURE_SENTENCE_ZH,
  CHAPTERS,
  LAYER_LABELS_ZH,
  LAYERS_ZH,
  chapterNavItems,
  type ChapterId,
} from "../lib/chapters";

const nav = chapterNavItems();

function chapterLinks(ids: ChapterId[]) {
  return ids.map((id) => CHAPTERS.find((c) => c.id === id)!);
}
---

<ReportLayout
  title="用 Maka 解剖 Agent · Agent Atelier"
  description="Maka 是 log-first、projection-driven 的 Agent Runtime。沿六章里程碑理解完整 Agent 结构。"
  nav={nav}
  activeHref="/"
>
  <article class="report">
    <header class="masthead">
      <p class="masthead__eyebrow">Agent Learning Report · Specimen: Maka</p>
      <h1>用 Maka 解剖 Agent</h1>
      <p class="masthead__sub masthead__sub--architecture">
        {ARCHITECTURE_SENTENCE_ZH}
      </p>
      <div class="masthead__meta">
        <span>认知轨 · §01–§06</span>
        <span>标本 · maka-agent</span>
        <span>体裁 · research report</span>
        <span>
          演进轨 · <a href="/history">/history</a>
        </span>
      </div>
    </header>

    <Section
      id="layers"
      label="Mental model"
      title="三层心智模型"
      lede="同一组运行事实，被投影给不同消费者；先分清层，再进章节。"
    >
      <ol class="layer-list">
        {
          LAYERS_ZH.map((layer) => (
            <li class="layer-card">
              <p class="layer-card__n">
                {layer.n}. {layer.title}
              </p>
              <p class="layer-card__body">{layer.body}</p>
              <p class="layer-card__chapters">
                对应章节：
                {chapterLinks(layer.chapters).map((c, i) => (
                  <span>
                    {i > 0 ? " · " : ""}
                    <a href={c.href}>
                      §{c.id} {c.titleZh}
                    </a>
                  </span>
                ))}
              </p>
            </li>
          ))
        }
      </ol>
    </Section>

    <Section
      id="chapters"
      label="Six chapters"
      title="六章索引"
      lede="路由与 Maka ARCHITECTURE 英文章名 1:1；全部为 WIP，未标完成。"
    >
      <ol class="chapter-toc">
        {
          CHAPTERS.map((c) => (
            <li class="chapter-toc__item">
              <a class="chapter-toc__link" href={c.href}>
                <span class="chapter-toc__id">§{c.id}</span>
                <span class="chapter-toc__titles">
                  <span class="chapter-toc__zh">{c.titleZh}</span>
                  <span class="chapter-toc__en">{c.titleEn}</span>
                </span>
                <span class="chapter-toc__meta">
                  <span class="chapter-toc__layer">{LAYER_LABELS_ZH[c.layer]}</span>
                  <span class="chapter-toc__wip">WIP</span>
                </span>
              </a>
              <p class="chapter-toc__q">{c.questionZh}</p>
            </li>
          ))
        }
      </ol>
    </Section>

    <Section
      id="tracks"
      label="Dual track"
      title="认知轨与演进轨"
      lede="里程碑讲透结构；完整 commit/PR 谱系在 /history。"
    >
      <p>
        认知轨按六章里程碑推进，不把仓库每一笔提交摊成目录。需要追「这一机制何时长成」时，进入
        <a href="/history">/history</a>
        （PR-first 快照），或在章内稀疏的演进旁注中跳转。
      </p>
      <blockquote class="pull">
        目标读者不是「只会调 API 的人」，而是想弄清 Agent
        内部账本怎么记、上下文怎么瘦、失败怎么复盘、系统如何可证伪地改进的人。
      </blockquote>
    </Section>
  </article>
</ReportLayout>

<style>
  .masthead__sub--architecture {
    font-style: normal;
    font-size: 1.12rem;
    line-height: 1.65;
    color: var(--ink);
    max-width: 42em;
  }

  .layer-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
  }

  .layer-card {
    padding: 0 0 1.35rem;
    border-bottom: 1px solid var(--hair);
  }

  .layer-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .layer-card__n {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.45rem;
  }

  .layer-card__body {
    font-family: var(--serif);
    margin: 0 0 0.65rem;
    max-width: 40em;
  }

  .layer-card__chapters {
    margin: 0;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--mute);
  }

  .chapter-toc {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .chapter-toc__item {
    padding: 1.15rem 0;
    border-bottom: 1px solid var(--hair);
  }

  .chapter-toc__item:last-child {
    border-bottom: none;
  }

  .chapter-toc__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.75rem 1rem;
    align-items: baseline;
    text-decoration: none;
    color: inherit;
  }

  .chapter-toc__link:hover .chapter-toc__zh {
    color: var(--accent);
  }

  .chapter-toc__id {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--accent);
  }

  .chapter-toc__titles {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .chapter-toc__zh {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.2rem;
    transition: color 0.15s ease;
  }

  .chapter-toc__en {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--mute);
  }

  .chapter-toc__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--mute);
  }

  .chapter-toc__wip {
    color: var(--accent);
  }

  .chapter-toc__q {
    margin: 0.55rem 0 0 0;
    padding-left: calc(0.78rem * 3.2);
    font-family: var(--serif);
    font-size: 0.98rem;
    color: var(--mute);
    max-width: 40em;
  }

  @media (max-width: 640px) {
    .chapter-toc__link {
      grid-template-columns: auto 1fr;
    }

    .chapter-toc__meta {
      grid-column: 2;
      flex-direction: row;
      align-items: center;
      gap: 0.75rem;
    }

    .chapter-toc__q {
      padding-left: 0;
    }
  }
</style>
