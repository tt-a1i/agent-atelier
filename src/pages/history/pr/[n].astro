---
import ReportLayout from "../../../layouts/ReportLayout.astro";
import { chapterNavItems } from "../../../lib/chapters";
import {
  getCommitBySha,
  getPr,
  githubCommitUrl,
  loadMeta,
  loadPrs,
  prAreaChips,
} from "../../../lib/maka-history";

export function getStaticPaths() {
  return loadPrs().map((pr) => ({
    params: { n: String(pr.number) },
  }));
}

const n = Number(Astro.params.n);
const pr = getPr(n);
if (!pr) {
  throw new Error(`PR #${n} missing from snapshot (stale getStaticPaths?)`);
}

const meta = loadMeta();
const memberCommits = pr.commitShas
  .map((sha) => getCommitBySha(sha))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));
const chips = prAreaChips(pr, 8);

const nav = chapterNavItems();

function fmtDate(iso: string): string {
  try {
    return new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date(iso));
  } catch {
    return iso;
  }
}
---

<ReportLayout
  title={`PR #${pr.number} · ${pr.title} · Agent Atelier`}
  description={`Maka PR #${pr.number}: ${pr.title}`}
  nav={nav}
>
  <article class="report">
    <header class="masthead">
      <p class="masthead__eyebrow">History · PR · maka:pr:{pr.number}</p>
      <h1>
        <span class="pr-num">#{pr.number}</span>
        {pr.title}
      </h1>
      <p class="masthead__sub">
        档案详情（无内嵌 diff）。补丁请到 GitHub 查看。Archive pin {meta.source.sourceShort}.
      </p>
      <div class="masthead__meta">
        <span>{pr.author}</span>
        <span>merged · {fmtDate(pr.mergedAt)}</span>
        <span>{pr.baseRef} ← {pr.headRef}</span>
        {
          chips.length > 0 && (
            <span class="meta-chips">
              {chips.map((c) => (
                <span class="chip">{c}</span>
              ))}
            </span>
          )
        }
      </div>
    </header>

    <section class="section" aria-labelledby="commits-heading">
      <p class="section__label">Member commits</p>
      <h2 id="commits-heading">纳入本 PR 的提交</h2>
      <p class="section__lede">
        {
          memberCommits.length > 0
            ? `共 ${memberCommits.length} 条（由 subject (#N) 与 merge commit 关联）。`
            : "快照中尚无关联 commit（仍可从 GitHub 打开 PR）。"
        }
      </p>
      {
        memberCommits.length > 0 && (
          <ul class="commit-list">
            {memberCommits.map((c) => (
              <li>
                <a href={`/history/c/${c.short}`}>
                  <code>{c.short}</code>
                  <span>{c.subject}</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <aside class="stub">
      <p class="stub__tag">Outbound</p>
      <p>
        <a href={pr.url} rel="noopener noreferrer">在 GitHub 打开 PR #{pr.number}</a>
        {
          pr.mergeCommitSha && (
            <>
              {" · "}
              <a href={githubCommitUrl(pr.mergeCommitSha)} rel="noopener noreferrer">
                merge commit
              </a>
            </>
          )
        }
      </p>
    </aside>
  </article>
</ReportLayout>

<style>
  .pr-num {
    color: var(--accent);
    margin-right: 0.35rem;
  }

  .meta-chips {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .chip {
    padding: 0.05rem 0.35rem;
    border: 1px solid var(--hair);
    background: var(--softer);
  }

  .commit-list {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .commit-list li {
    border-bottom: 1px solid var(--hair);
  }

  .commit-list li:first-child {
    border-top: 1px solid var(--hair);
  }

  .commit-list a {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    padding: 0.7rem 0;
    text-decoration: none;
    color: inherit;
  }

  .commit-list a:hover span {
    color: var(--accent);
  }

  .commit-list code {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
  }

  .commit-list span {
    font-family: var(--serif);
    font-size: 1rem;
  }
</style>
