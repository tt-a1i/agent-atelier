---
import ReportLayout from "../../../layouts/ReportLayout.astro";
import { chapterNavItems } from "../../../lib/chapters";
import {
  getCommitByShort,
  githubCommitUrl,
  loadCommits,
  loadMeta,
} from "../../../lib/maka-history";

export function getStaticPaths() {
  return loadCommits().map((c) => ({
    params: { short: c.short },
  }));
}

const short = Astro.params.short!;
const commit = getCommitByShort(short);
if (!commit) {
  throw new Error(`Commit ${short} missing from snapshot (stale getStaticPaths?)`);
}

const meta = loadMeta();
const nav = chapterNavItems();

function fmtDate(iso: string): string {
  try {
    return new Intl.DateTimeFormat("zh-CN", {
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date(iso));
  } catch {
    return iso;
  }
}
---

<ReportLayout
  title={`${commit.short} · ${commit.subject} · Agent Atelier`}
  description={`Maka commit ${commit.short}: ${commit.subject}`}
  nav={nav}
>
  <article class="report">
    <header class="masthead">
      <p class="masthead__eyebrow">History · Commit · maka:commit:{commit.sha}</p>
      <h1>
        <code class="sha">{commit.short}</code>
        {commit.subject}
      </h1>
      <p class="masthead__sub">
        档案详情（无内嵌 diff）。Archive pin {meta.source.sourceShort}.
      </p>
      <div class="masthead__meta">
        <span>{commit.author.name}</span>
        <span>{fmtDate(commit.committer.date)}</span>
        <span>
          {commit.stats.files} files · +{commit.stats.additions} / −{commit.stats.deletions}
        </span>
      </div>
    </header>

    {
      commit.prNumbers.length > 0 && (
        <section class="section" aria-labelledby="pr-heading">
          <p class="section__label">Associated PRs</p>
          <h2 id="pr-heading">关联 PR</h2>
          <ul class="pr-list">
            {commit.prNumbers.map((num) => (
              <li>
                <a href={`/history/pr/${num}`}>#{num}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      commit.pathPrefixes.length > 0 && (
        <section class="section" aria-labelledby="area-heading">
          <p class="section__label">Areas</p>
          <h2 id="area-heading">触及路径前缀</h2>
          <p class="chips">
            {commit.pathPrefixes.map((p) => (
              <span class="chip">{p}</span>
            ))}
          </p>
        </section>
      )
    }

    {
      commit.body && (
        <section class="section" aria-labelledby="body-heading">
          <p class="section__label">Message body</p>
          <h2 id="body-heading">说明</h2>
          <pre class="body">{commit.body}</pre>
        </section>
      )
    }

    <aside class="stub">
      <p class="stub__tag">Outbound</p>
      <p>
        <a href={githubCommitUrl(commit.sha)} rel="noopener noreferrer">
          在 GitHub 打开 {commit.short}
        </a>
      </p>
    </aside>
  </article>
</ReportLayout>

<style>
  .sha {
    font-family: var(--mono);
    font-size: 0.85em;
    color: var(--accent);
    margin-right: 0.4rem;
  }

  .pr-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    font-family: var(--mono);
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1rem 0 0;
  }

  .chip {
    font-family: var(--mono);
    font-size: 0.72rem;
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--hair);
    background: var(--softer);
    color: var(--mute);
  }

  .body {
    margin: 1rem 0 0;
    padding: 1rem 1.1rem;
    background: var(--soft);
    border: 1px solid var(--hair);
    font-family: var(--mono);
    font-size: 0.82rem;
    line-height: 1.55;
    white-space: pre-wrap;
    overflow-x: auto;
  }
</style>
