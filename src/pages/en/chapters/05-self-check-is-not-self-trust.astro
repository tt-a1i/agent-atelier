      <SelfCheckKeystone />
    </DiagramFigure>
    <aside class="history-aside">
      <p class="history-aside__tag">Evolution aside</p>
      <p>
        Architecture chapter: <a href="/history/pr/774">maka:pr:774</a>.
      </p>
